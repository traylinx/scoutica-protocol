{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Scoutica Protocol",
  "theme": "sequoia",
  "colors": {
    "primary": "#8800ff",
    "light": "#8800ff",
    "dark": "#c084fc"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/traylinx/scoutica-protocol"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/traylinx/scoutica-protocol"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "installation"
            ]
          },
          {
            "group": "CLI Reference",
            "pages": [
              "cli/overview",
              "cli/init",
              "cli/scan",
              "cli/validate",
              "cli/publish",
              "cli/preview",
              "cli/resolve",
              "cli/info",
              "cli/doctor",
              "cli/update"
            ]
          },
          {
            "group": "Your Skill Card",
            "pages": [
              "skill-card/overview",
              "skill-card/profile",
              "skill-card/rules",
              "skill-card/evidence",
              "skill-card/discovery"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/create-card",
              "guides/privacy-zones",
              "guides/use-cases",
              "guides/troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "Developer Guide",
        "groups": [
          {
            "group": "Integration",
            "pages": [
              "developer/overview",
              "developer/fetching-cards",
              "developer/discovery-protocol",
              "developer/evaluating-candidates",
              "developer/evidence-verification",
              "developer/schema-validation"
            ]
          },
          {
            "group": "Architecture",
            "pages": [
              "architecture/overview",
              "architecture/six-pillars",
              "architecture/data-model",
              "architecture/compliance"
            ]
          },
          {
            "group": "Roadmap",
            "pages": [
              "roadmap"
            ]
          }
        ]
      }
    ]
  },
  "appearance": {
    "strict": false,
    "default": "dark"
  },
  "background": {
    "color": {
      "dark": "#000000",
      "light": "#ffffff"
    }
  },
  "favicon": "/images/favicon.ico"
}
