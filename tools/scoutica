# Build rules as a dict, write with yaml or manual safe format
rules = {"schema_version": "0.1.0"}
engagement = {"allowed_types": csv_to_list(engagement_csv)}
comp = {}
for key, val in [("permanent", comp_perm), ("contract", comp_contract), ("advisory", comp_advisory)]:
