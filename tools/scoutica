        "wss://nos.lol"
    ]
}

# Save keypair (private — never share)
keypair_file = os.path.join(identity_dir, "keypair.json")
with open(keypair_file, "w") as f:
    json.dump(identity, f, indent=2)
    f.write("\n")
os.chmod(keypair_file, 0o600)

# Save public-only file (safe to share)
public_file = os.path.join(identity_dir, "public.json")
public = {
    "public_key_hex": pubkey_hash,
    "npub": npub_placeholder,
    "default_relays": identity["default_relays"],
    "created_at": now,
}
with open(public_file, "w") as f:
    json.dump(public, f, indent=2)
    f.write("\n")

print(f"  ✅ Nostr identity generated!")
print()
print(f"  🔑 Public key (share this):")
print(f"     {npub_placeholder}")
print()
print(f"  🔒 Private key (NEVER share):")
print(f"     Stored at: {keypair_file} (chmod 600)")
print()
print(f"  📡 Default relays:")
for relay in identity["default_relays"]:
    print(f"     • {relay}")
print()
print(f"  ⚠️  NOTE: These are placeholder keys using SHA-256 derivation.")
print(f"     For production use, install python-nostr for proper secp256k1:")
print(f"     pip install python-nostr")
print()
print(f"  📋 Next steps:")
print(f"     1. Add your pubkey to scoutica.json:")
print(f"        \"transport\": {{")
print(f"          \"preferred\": \"nostr\",")
print(f"          \"nostr\": {{")
print(f"            \"pubkey\": \"{npub_placeholder}\",")
print(f"            \"relays\": [\"wss://relay.damus.io\"]")
print(f"          }}")
print(f"        }}")
print(f"     2. Publish your updated card: scoutica publish")
IDENTITY_SCRIPT
    
    echo ""
}

