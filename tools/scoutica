# ─── Logging Infrastructure ───────────────────────────────────────────────────

_SCAN_LOG_FILE=""
_SCAN_T0=""
_SCAN_T_AI_START=""
_SCAN_T_AI_END=""

_ts_ms() {
    # Millisecond timestamp (macOS + Linux compatible)
    # macOS date does NOT support %N — it outputs literal 'N'
    if command -v gdate &>/dev/null; then
        gdate +%s%3N
    else
        # Seconds-only fallback (multiply by 1000)
        echo $(( $(date +%s) * 1000 ))
    fi
}

_scan_log_init() {
    mkdir -p "$LOGS_DIR"
    _SCAN_LOG_FILE="$LOGS_DIR/scan_$(date +%Y-%m-%d_%H%M%S).log"
    _SCAN_T0=$(_ts_ms)
    _scan_log "INIT" "scan started, version=$VERSION"
}

_scan_log() {
    local step="$1" msg="$2"
    local ts=$(date +%H:%M:%S)
    [ -n "$_SCAN_LOG_FILE" ] && echo "[$ts] [$step] $msg" >> "$_SCAN_LOG_FILE"
}

_scan_log_timing() {
    local t_now=$(_ts_ms)
    local total_ms=$(( t_now - ${_SCAN_T0:-$t_now} ))
    local extract_ms=$(( ${_SCAN_T_AI_START:-$t_now} - ${_SCAN_T0:-$t_now} ))
    local ai_ms=$(( ${_SCAN_T_AI_END:-$t_now} - ${_SCAN_T_AI_START:-$t_now} ))
    local parse_ms=$(( t_now - ${_SCAN_T_AI_END:-$t_now} ))
    
    local total_s=$(python3 -c "print(f'{$total_ms/1000:.1f}')" 2>/dev/null || echo "$((total_ms/1000))")
    local extract_s=$(python3 -c "print(f'{$extract_ms/1000:.1f}')" 2>/dev/null || echo "$((extract_ms/1000))")
    local ai_s=$(python3 -c "print(f'{$ai_ms/1000:.1f}')" 2>/dev/null || echo "$((ai_ms/1000))")
    local parse_s=$(python3 -c "print(f'{$parse_ms/1000:.1f}')" 2>/dev/null || echo "$((parse_ms/1000))")
    
    # Calculate percentages
    local extract_pct=0 ai_pct=0 parse_pct=0
    if [ "$total_ms" -gt 0 ]; then
        extract_pct=$(python3 -c "print(f'{$extract_ms/$total_ms*100:.1f}')" 2>/dev/null || echo "0")
        ai_pct=$(python3 -c "print(f'{$ai_ms/$total_ms*100:.1f}')" 2>/dev/null || echo "0")
        parse_pct=$(python3 -c "print(f'{$parse_ms/$total_ms*100:.1f}')" 2>/dev/null || echo "0")
    fi
    
    _scan_log "TIMING" "total=${total_s}s, extraction=${extract_s}s (${extract_pct}%), ai=${ai_s}s (${ai_pct}%), parse+write=${parse_s}s (${parse_pct}%)"
    
    echo ""
    echo -e "  ${DIM}⏱️  Timing breakdown:${NC}"
    echo -e "      ${DIM}Extraction:${NC}  ${BOLD}${extract_s}s${NC}   ${DIM}(${extract_pct}%)${NC}"
    echo -e "      ${DIM}AI response:${NC} ${BOLD}${ai_s}s${NC}   ${DIM}(${ai_pct}%)${NC}"
    echo -e "      ${DIM}Parse+Write:${NC} ${BOLD}${parse_s}s${NC}   ${DIM}(${parse_pct}%)${NC}"
    echo -e "      ${DIM}Total:${NC}       ${BOLD}${total_s}s${NC}"
    echo -e "  ${DIM}📋 Full log: $_SCAN_LOG_FILE${NC}"
}

# ─── Extraction Cache ─────────────────────────────────────────────────────────

_cache_get() {
    local file_hash="$1"
    local cache_file="$CACHE_DIR/extracted_texts.json"
    [ -f "$cache_file" ] || return 1
    python3 - "$file_hash" "$cache_file" <<'CACHE_GET_PY' 2>/dev/null
import json, sys
try:
    fhash = sys.argv[1]
    with open(sys.argv[2]) as f:
        cache = json.load(f)
    text = cache.get(fhash)
    if text:
        print(text, end='')
        sys.exit(0)
    sys.exit(1)
except:
    sys.exit(1)
CACHE_GET_PY
}

_cache_set() {
    local file_hash="$1"
    local text="$2"
    mkdir -p "$CACHE_DIR"
    local cache_file="$CACHE_DIR/extracted_texts.json"
    # Write text to temp file to avoid ARG_MAX and stdin conflicts
    local tmp_text=$(mktemp /tmp/scoutica_cache.XXXXXX)
    printf '%s' "$text" > "$tmp_text"
    python3 - "$file_hash" "$cache_file" "$tmp_text" <<'CACHE_SET_PY' 2>/dev/null || true
import json, sys
fhash = sys.argv[1]
cache_file = sys.argv[2]
with open(sys.argv[3]) as f:
    text = f.read()
try:
    with open(cache_file) as f:
        cache = json.load(f)
except:
    cache = {}
cache[fhash] = text
# Keep cache small: max 100 entries, evict oldest by sorted hash
if len(cache) > 100:
    keys = sorted(cache.keys())
    for k in keys[:len(cache)-100]:
        del cache[k]
with open(cache_file, 'w') as f:
    json.dump(cache, f)
CACHE_SET_PY
    rm -f "$tmp_text"
}

_file_sha256() {
    shasum -a 256 "$1" 2>/dev/null | awk '{print $1}'
}

# ─── LOGS Command ─────────────────────────────────────────────────────────────

cmd_logs() {
    local action="${1:-show}"
    
    case "$action" in
        --list|list)
            if [ -d "$LOGS_DIR" ] && ls "$LOGS_DIR"/scan_*.log &>/dev/null; then
                header "Scan Logs"
                ls -lt "$LOGS_DIR"/scan_*.log | head -20 | while IFS= read -r line; do
                    echo -e "  ${DIM}$line${NC}"
                done
            else
                warn "No scan logs found in $LOGS_DIR"
            fi
            ;;
        --clear|clear)
            if [ -d "$LOGS_DIR" ]; then
                local count=$(ls "$LOGS_DIR"/scan_*.log 2>/dev/null | wc -l | tr -d ' ')
                if [ "$count" -gt 0 ] 2>/dev/null; then
                    rm -f "$LOGS_DIR"/scan_*.log
                    success "Cleared $count scan log(s)"
                else
                    warn "No scan logs to clear"
                fi
            else
                warn "No logs directory found"
            fi
            ;;
        *)
            # Show the most recent log
            local latest=$(ls -t "$LOGS_DIR"/scan_*.log 2>/dev/null | head -1)
            if [ -n "$latest" ]; then
                header "Latest Scan Log"
                echo -e "  ${DIM}File: $latest${NC}"
                echo ""
                cat "$latest" | while IFS= read -r line; do
                    echo -e "  $line"
                done
            else
                warn "No scan logs found. Run 'scoutica scan' first."
            fi
            ;;
    esac
}

