}

cmd_role_create() {
    local target_dir="${1:-.}"
    
    header "Create Structured Job Posting"
    
    echo -e "  ${DIM}Define the role using the Scoutica Protocol format.${NC}"
    echo -e "  ${DIM}This creates a machine-readable role.json for deterministic matching.${NC}"
    echo ""
    
    # ── Role Identity ──
    echo -e "  ${MAGENTA}━━━ 📋 Role Details ━━━${NC}"
    echo ""
    local role_title=$(ask "Role title" "Senior Software Engineer")
    local role_description=$(ask "Short role description")
    local role_seniority=$(ask_choice "Seniority" \
        "entry" "junior" "mid" "senior" "lead" "manager" "director" "executive")
    local min_years=$(ask "Minimum years of experience" "5")
    
    echo ""
    
    # ── Skills ──
    echo -e "  ${MAGENTA}━━━ 🛠️  Skills ━━━${NC}"
    echo ""
    local hard_skills=$(ask_list "Required skills (hard)" "e.g. Python, Kubernetes, SQL")
    local preferred_skills=$(ask_list "Preferred skills (nice-to-have)" "e.g. Rust, NATS")
    local soft_skills=$(ask_list "Soft skills" "e.g. Leadership, Mentorship")
    local languages_required=$(ask_list "Languages required" "e.g. English, German")
    
    echo ""
    
    # ── Compensation ──
    echo -e "  ${MAGENTA}━━━ 💰 Compensation ━━━${NC}"
    echo ""
    local currency=$(ask "Currency (3-letter code)" "EUR")
    local base_min=$(ask "Minimum base salary" "80000")
    local base_max=$(ask "Maximum base salary" "120000")
    local equity=$(confirm "Equity offered?" && echo "true" || echo "false")
    
    echo ""
    
    # ── Location ──
    echo -e "  ${MAGENTA}━━━ 🌍 Location ━━━${NC}"
    echo ""
    local location_type=$(ask_choice "Work model" "remote" "hybrid" "onsite")
    local regions=$(ask_list "Regions allowed" "e.g. EU, UK, US-East")
    local tz_overlap=$(ask "Timezone overlap required" "CET ±2h")
    local office_location=""
    if [ "$location_type" != "remote" ]; then
        office_location=$(ask "Office location")
    fi
    
    echo ""
    
    # ── Engagement ──
    echo -e "  ${MAGENTA}━━━ 📅 Engagement ━━━${NC}"
    echo ""
    local engagement_type=$(ask_choice "Engagement type" "permanent" "contract" "fractional" "freelance")
    local start_date=$(ask "Start date (YYYY-MM-DD)" "")
    local duration_months=""
    if [ "$engagement_type" != "permanent" ]; then
        duration_months=$(ask "Duration (months)" "")
    fi
    
    echo ""
    
    # ── Recruiter Card URL ──
    local recruiter_card_url=""
    if [ -f "$target_dir/recruiter_profile.json" ]; then
        recruiter_card_url=$(python3 -c "import json; d=json.load(open('$target_dir/recruiter_profile.json')); print(d.get('card_url',''))" 2>/dev/null || echo "")
    fi
    if [ -z "$recruiter_card_url" ]; then
        recruiter_card_url=$(ask "Recruiter card URL (optional)" "")
    fi
    
    # ── Generate ──
    header "Generating Role Posting"
    
    mkdir -p "$target_dir/roles"
    
    python3 << 'ROLE_GENERATE_SCRIPT' - \
        "$target_dir" \
        "$role_title" "$role_description" "$role_seniority" "$min_years" \
        "$hard_skills" "$preferred_skills" "$soft_skills" "$languages_required" \
        "$currency" "$base_min" "$base_max" "$equity" \
        "$location_type" "$regions" "$tz_overlap" "$office_location" \
        "$engagement_type" "$start_date" "$duration_months" \
        "$recruiter_card_url"
import json, sys, os, re, hashlib
from datetime import datetime, timezone, timedelta

args = sys.argv[1:]
target_dir = args[0]
role_title, role_desc, seniority, min_years_str = args[1:5]
hard_csv, preferred_csv, soft_csv, languages_csv = args[5:9]
currency, base_min_str, base_max_str, equity_str = args[9:13]
location_type, regions_csv, tz_overlap, office_loc = args[13:17]
engagement_type, start_date, duration_str = args[17:20]
recruiter_card_url = args[20] if len(args) > 20 else ""

def csv_to_list(s):
    return [x.strip() for x in s.split(',') if x.strip()] if s else []

def safe_int(s, default=0):
    try: return int(s)
    except: return default

now = datetime.now(timezone.utc)
expiry = now + timedelta(days=30)

# Generate a deterministic job_id from title
title_hash = hashlib.sha256(f"{role_title}:{now.isoformat()}".encode()).hexdigest()[:6]
job_id = f"req_{title_hash}"

role = {
    "scoutica_version": "0.3.0",
    "job_id": job_id,
    "title": role_title,
    "status": "active",
    "posted_at": now.strftime("%Y-%m-%dT%H:%M:%SZ"),
    "expires_at": expiry.strftime("%Y-%m-%dT%H:%M:%SZ"),
    "refreshed_at": now.strftime("%Y-%m-%dT%H:%M:%SZ"),
    "requirements": {
        "hard_skills": csv_to_list(hard_csv),
        "seniority": seniority,
        "minimum_years_experience": safe_int(min_years_str, 5),
    },
    "compensation": {
        "currency": currency.upper(),
        "base_min": safe_int(base_min_str, 80000),
        "base_max": safe_int(base_max_str, 120000),
        "equity_offered": equity_str == "true",
    },
    "location": {
        "type": location_type,
    },
    "engagement": {
        "type": engagement_type,
    },
    "description": role_desc,
}

# Optional fields
if csv_to_list(preferred_csv):
    role["requirements"]["preferred_skills"] = csv_to_list(preferred_csv)
if csv_to_list(soft_csv):
    role["requirements"]["soft_skills"] = csv_to_list(soft_csv)
if csv_to_list(languages_csv):
    role["requirements"]["languages_required"] = csv_to_list(languages_csv)
if csv_to_list(regions_csv):
    role["location"]["regions_allowed"] = csv_to_list(regions_csv)
if tz_overlap:
    role["location"]["timezone_overlap_required"] = tz_overlap
if office_loc:
    role["location"]["office_location"] = office_loc
if start_date:
    role["engagement"]["start_date"] = start_date
if duration_str:
    role["engagement"]["duration_months"] = safe_int(duration_str)
if recruiter_card_url:
    role["recruiter_card_url"] = recruiter_card_url

# Generate filename from title
filename = re.sub(r'[^a-z0-9]+', '-', role_title.lower()).strip('-') + '.json'
filepath = os.path.join(target_dir, 'roles', filename)

with open(filepath, 'w') as f:
    json.dump(role, f, indent=2, ensure_ascii=False)
    f.write('\n')
print(f"  ✅ Created roles/{filename}")
print(f"     Job ID: {job_id}")
print(f"     Expires: {expiry.strftime('%Y-%m-%d')} (30 days — refresh to prevent ghost-job decay)")
ROLE_GENERATE_SCRIPT
    
    echo ""
    echo -e "  ${BOLD}Next steps:${NC}"
    echo -e "  ${CYAN}scoutica role validate${NC}    Validate against protocol schemas"
    echo -e "  ${CYAN}scoutica org publish${NC}      Push to GitHub"
    echo ""
}

cmd_role_validate() {
    local card_dir="${1:-.}"
    
    header "Validate Role Postings"
    
    # Find Python
    local python_cmd=""
    if command -v python3 &>/dev/null; then
        python_cmd="python3"
    elif command -v python &>/dev/null; then
        python_cmd="python"
    else
        error "Python is required for schema validation"
        exit 1
    fi
    
    # Find validator script
    local validator=""
    local script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    
    if [ -f "$SCOUTICA_HOME/bin/validate_card.py" ]; then
        validator="$SCOUTICA_HOME/bin/validate_card.py"
    elif [ -f "$script_dir/validate_card.py" ]; then
        validator="$script_dir/validate_card.py"
    elif [ -f "$SCOUTICA_HOME/tools/validate_card.py" ]; then
        validator="$SCOUTICA_HOME/tools/validate_card.py"
    fi
    
    if [ -z "$validator" ]; then
        error "Validation script not found."
        exit 1
    fi
    
    # Check for dependencies
    if ! $python_cmd -c "import jsonschema, yaml" 2>/dev/null; then
        warn "Missing Python dependencies. Installing..."
        $python_cmd -m pip install jsonschema pyyaml --quiet 2>/dev/null || {
            error "Failed to install dependencies"
            exit 1
        }
    fi
    
    $python_cmd "$validator" "$card_dir" --type employer
}

# ─── EVALUATE Command (Fit Scoring) ───────────────────────────────────────────

cmd_evaluate() {
    local profile_path=""
    local rules_path=""
    local role_path=""
    local recruiter_path=""
    local output_json=false
    local batch_mode=false
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)   output_json=true; shift ;;
            --batch)  batch_mode=true; shift ;;
            --role)   role_path="$2"; shift 2 ;;
            --recruiter) recruiter_path="$2"; shift 2 ;;
            *)
                if [ -z "$profile_path" ]; then
                    profile_path="$1"
                elif [ -z "$role_path" ]; then
                    role_path="$1"
                fi
                shift
                ;;
        esac
    done
    
    header "Scoutica Fit Evaluation"
    
    # Find scoring engine
    local script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local scorer=""
    if [ -f "$script_dir/scoring.py" ]; then
        scorer="$script_dir/scoring.py"
    elif [ -f "$SCOUTICA_HOME/bin/scoring.py" ]; then
        scorer="$SCOUTICA_HOME/bin/scoring.py"
    elif [ -f "$SCOUTICA_HOME/tools/scoring.py" ]; then
        scorer="$SCOUTICA_HOME/tools/scoring.py"
    fi
    
    if [ -z "$scorer" ]; then
        error "Scoring engine not found (scoring.py)"
        exit 1
    fi
    
    # Auto-detect card files from directory
    if [ -z "$profile_path" ]; then
        profile_path="."
    fi
    
    if [ -d "$profile_path" ]; then
        # It's a directory — look for card files
        local card_dir="$profile_path"
        if [ -f "$card_dir/profile.json" ]; then
            profile_path="$card_dir/profile.json"
            if [ -f "$card_dir/rules.yaml" ]; then
                rules_path="$card_dir/rules.yaml"
            fi
        else
            error "No profile.json found in $card_dir"
            exit 1
        fi
    else
        # Profile is a file — look for rules.yaml next to it
        local card_dir="$(dirname "$profile_path")"
        if [ -f "$card_dir/rules.yaml" ]; then
            rules_path="$card_dir/rules.yaml"
        fi
    fi
    
    if [ -z "$role_path" ]; then
        error "No role specified. Usage: scoutica evaluate <card_dir> <role.json>"
        echo -e "  ${DIM}Example: scoutica evaluate ./my-card roles/senior-engineer.json${NC}"
        exit 1
    fi
    
    if [ ! -f "$role_path" ]; then
        error "Role file not found: $role_path"
        exit 1
    fi
    
    # Build scoring command
    local args=()
    if $output_json; then
        args+=("--json")
    fi
    args+=("$profile_path")
    args+=("${rules_path:-/dev/null}")
    args+=("$role_path")
    if [ -n "$recruiter_path" ] && [ -f "$recruiter_path" ]; then
        args+=("$recruiter_path")
    fi
    
    python3 "$scorer" "${args[@]}"
}

