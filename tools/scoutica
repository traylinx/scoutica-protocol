# ─── UPDATE Command ───────────────────────────────────────────────────────────

cmd_update() {
    header "Updating Scoutica Protocol CLI"
    echo -e "  ${DIM}Checking for updates...${NC}"
    echo ""
    
    local remote_version
    remote_version=$(curl -fsSL "https://raw.githubusercontent.com/traylinx/scoutica-protocol/main/tools/scoutica" 2>/dev/null | grep '^VERSION=' | head -1 | cut -d'"' -f2 || true)
    
    echo -e "  Current: ${CYAN}v$VERSION${NC}"
    echo -e "  Latest:  ${CYAN}v${remote_version:-unknown}${NC}"
    
    if [ -n "$remote_version" ] && [ "$VERSION" = "$remote_version" ]; then
        echo ""
        success "Already up to date!"
        return 0
    fi
    
    echo ""
    echo -e "  ${DIM}Running installer to fetch the latest version...${NC}"
    echo ""
    
    # Run the install script directly from the main branch
    curl -fsSL "https://raw.githubusercontent.com/traylinx/scoutica-protocol/main/install.sh" | bash
    
    local exit_code=$?
    if [ $exit_code -eq 0 ]; then
        echo ""
        success "Update complete! Run 'scoutica version' to check."
    else
        echo ""
        error "Update failed."
        exit 1
    fi
}

# ─── Generate scoutica.json ──────────────────────────────────────────────────

generate_scoutica_json() {
    local card_dir="$1"
    local profile_file="$card_dir/profile.json"
    
    [ ! -f "$profile_file" ] && return 1
    
    python3 << GENJSON
import json, sys, os
from datetime import date

card_dir = "$card_dir"
with open(os.path.join(card_dir, "profile.json")) as f:
    profile = json.load(f)

# Detect GitHub remote URL if in a git repo
card_url = ""
try:
    import subprocess
    result = subprocess.run(["git", "-C", card_dir, "remote", "get-url", "origin"],
                          capture_output=True, text=True)
    if result.returncode == 0:
        remote = result.stdout.strip()
        # Convert git URL to raw
        remote = remote.replace(".git", "")
        if "github.com" in remote:
            parts = remote.replace("https://github.com/", "").split("/")
            if len(parts) >= 2:
                card_url = f"https://raw.githubusercontent.com/{parts[0]}/{parts[1]}/main"
except: pass

discovery = {
    "scoutica": "0.1.0",
    "card_url": card_url,
    "name": profile.get("name", ""),
    "title": profile.get("title", ""),
    "seniority": profile.get("seniority", ""),
    "domains": profile.get("domains", []),
    "availability": profile.get("availability", ""),
    "entity_type": profile.get("entity_type", "human"),
    "updated": date.today().isoformat()
}

with open(os.path.join(card_dir, "scoutica.json"), "w") as f:
    json.dump(discovery, f, indent=2, ensure_ascii=False)
    f.write("\n")

print(f"  ✅ Generated scoutica.json")
GENJSON
}

# ─── Main Router ──────────────────────────────────────────────────────────────

main() {
    local command="${1:-help}"
    shift 2>/dev/null || true
    
    case "$command" in
        init)       cmd_init "$@" ;;
        scan)       cmd_scan "$@" ;;
        resolve)    cmd_resolve "$@" ;;
        validate)   cmd_validate "$@" ;;
        publish)    cmd_publish "$@" ;;
        info)       cmd_info "$@" ;;
        preview)    cmd_preview "$@" ;;
        update)     cmd_update "$@" ;;
        doctor)     cmd_doctor "$@" ;;
        help|--help|-h)  cmd_help ;;
        version|--version|-v) echo "scoutica v$VERSION" ;;
        *)
            error "Unknown command: $command"
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"

