            echo "$skills_summary"
            echo ""
        fi
    fi
    
    # ── Show rules summary ──
    if [ -n "$rules" ]; then
        local rules_summary
        rules_summary=$(echo "$rules" | python3 -c "
import sys, yaml
try:
    r = yaml.safe_load(sys.stdin)
    if r.get('compensation',{}).get('minimum_base_eur'):
        print(f\"  Minimum salary: {r['compensation']['minimum_base_eur']} EUR\")
    if r.get('remote',{}).get('policy'):
        print(f\"  Remote policy: {r['remote']['policy']}\")
    if r.get('engagement',{}).get('allowed_types'):
        print(f\"  Engagement: {', '.join(r['engagement']['allowed_types'])}\")
    blocked = r.get('auto_reject',{}).get('blocked_industries',[])
    if blocked:
        print(f\"  Blocked industries: {', '.join(blocked)}\")
except: pass
" 2>/dev/null)
        
        if [ -n "$rules_summary" ]; then
            echo -e "  ${BOLD}Rules of Engagement:${NC}"
            echo "$rules_summary"
            echo ""
        fi
    fi
    
    # ── Show evidence count ──
    if [ -n "$evidence" ]; then
        local ev_count
        ev_count=$(echo "$evidence" | python3 -c "import sys,json; print(len(json.load(sys.stdin).get('items',[])))" 2>/dev/null)
