# ─── Generate scoutica.json ──────────────────────────────────────────────────

generate_scoutica_json() {
    local card_dir="$1"
    local profile_file="$card_dir/profile.json"
    
    [ ! -f "$profile_file" ] && return 1
    
    python3 - "$card_dir" <<'GENJSON'
import json, sys, os
from datetime import date

card_dir = sys.argv[1]
with open(os.path.join(card_dir, "profile.json")) as f:
    profile = json.load(f)

# Detect GitHub remote URL if in a git repo
card_url = ""
try:
    import subprocess
    result = subprocess.run(["git", "-C", card_dir, "remote", "get-url", "origin"],
                          capture_output=True, text=True)
    if result.returncode == 0:
        remote = result.stdout.strip()
        remote = remote.replace(".git", "")
        if "github.com" in remote:
            parts = remote.replace("https://github.com/", "").split("/")
            if len(parts) >= 2:
                card_url = f"https://raw.githubusercontent.com/{parts[0]}/{parts[1]}/main"
except Exception: pass

discovery = {
    "scoutica": "0.1.0",
    "card_url": card_url,
    "name": profile.get("name", ""),
    "title": profile.get("title", ""),
    "seniority": profile.get("seniority", ""),
    "domains": profile.get("primary_domains", profile.get("domains", [])),
    "availability": profile.get("availability", ""),
    "entity_type": profile.get("entity_type", "human"),
    "updated": date.today().isoformat()
}

with open(os.path.join(card_dir, "scoutica.json"), "w") as f:
    json.dump(discovery, f, indent=2, ensure_ascii=False)
    f.write("\n")

print(f"  ✅ Generated scoutica.json")
GENJSON
}

# ─── STATUS Command ───────────────────────────────────────────────────────────

cmd_status() {
    header "Card Status Dashboard"
    
    if [ ! -f "$REGISTRY_FILE" ]; then
        echo -e "  ${DIM}No cards registered yet.${NC}"
        echo ""
        echo -e "  ${BOLD}Get started:${NC}"
        echo -e "  ${CYAN}scoutica scan <docs-folder>${NC}   Generate your first Skill Card"
        echo ""
        return 0
    fi
    
    python3 << 'STATUSSCRIPT' - "$REGISTRY_FILE"
import json, sys, os
from datetime import datetime

registry_file = sys.argv[1]

try:
    with open(registry_file) as f:
        registry = json.load(f)
except Exception as e:
    print(f"  ❌ Failed to read registry: {e}", file=sys.stderr)
    sys.exit(1)

cards = registry.get("cards", {})
if not cards:
    print("  No cards registered yet.")
    print("")
    print("  Get started:")
    print("  scoutica scan <docs-folder>   Generate your first Skill Card")
    sys.exit(0)

# Sort by last_scanned (most recent first)
sorted_cards = sorted(cards.values(), key=lambda c: c.get("last_scanned") or c.get("created_at") or "", reverse=True)

for card in sorted_cards:
    card_dir = card.get("card_dir", "?")
    name = card.get("name", "Unknown")
    title = card.get("title", "")
    exists = os.path.isdir(card_dir) if card_dir != "?" else False
    github_url = card.get("github_url")
    preview_url = card.get("preview_url")
    provider = card.get("provider", "?")
    scan_count = card.get("scan_count", 0)
    last_scanned = card.get("last_scanned", "")
    last_published = card.get("last_published")
    
    # Status icon
    if exists:
        status = "✅ Folder exists"
        icon = "📁"
    else:
        status = "❌ Folder deleted — run scoutica scan to regenerate"
        icon = "📁"
    
    print(f"  {icon} {card_dir}")
    if not exists:
        print(f"     \033[33m[MISSING]\033[0m")
    print(f"     Name:      {name}" + (f" — {title}" if title else ""))
    
    if github_url:
        print(f"     GitHub:    {github_url}")
    else:
        print(f"     GitHub:    \033[2mnot published yet\033[0m")
    
    if preview_url:
        print(f"     Preview:   {preview_url}")
    
    if last_scanned:
        scan_date = last_scanned[:10]
        print(f"     Last scan: {scan_date} ({provider})")
    
    if last_published:
        pub_date = last_published[:10]
        print(f"     Published: {pub_date}")
    
    print(f"     Scans:     {scan_count} total")
    print(f"     Status:    {status}")
    print("")

# Summary
total = len(sorted_cards)
published = sum(1 for c in sorted_cards if c.get("github_url"))
missing = sum(1 for c in sorted_cards if not os.path.isdir(c.get("card_dir", "?")))

print(f"  ─────────────────────────────────────")
print(f"  {total} card(s) total | {published} published | {missing} missing")
print("")
STATUSSCRIPT
}

