cmd_jobs_search() {
    local skills_filter=""
    local seniority_filter=""
    local search_type="candidates"
    local registry_url="https://raw.githubusercontent.com/traylinx/scoutica-registry/main"
    local local_index=""
    local output_json=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --skills)    skills_filter="$2"; shift 2 ;;
            --seniority) seniority_filter="$2"; shift 2 ;;
            --type)      search_type="$2"; shift 2 ;;
            --registry)  registry_url="$2"; shift 2 ;;
            --local)     local_index="$2"; shift 2 ;;
            --json)      output_json=true; shift ;;
            *)           shift ;;
        esac
    done
    
    header "Scoutica Network Search"
    
    echo -e "  ${DIM}Searching ${search_type}...${NC}"
    
    local script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    
    python3 - "$search_type" "$skills_filter" "$seniority_filter" "$registry_url" "$local_index" "$output_json" "$script_dir" <<'SEARCH_SCRIPT'
import json, sys, os
try:
    from urllib.request import urlopen, Request
except ImportError:
    pass

search_type = sys.argv[1]
skills_filter = sys.argv[2]
seniority_filter = sys.argv[3]
registry_url = sys.argv[4]
local_index = sys.argv[5]
output_json = sys.argv[6] == "true"
script_dir = sys.argv[7] if len(sys.argv) > 7 else "."

# Load index
index = None
if local_index and os.path.exists(local_index):
    with open(local_index) as f:
        index = json.load(f)
else:
    index_url = f"{registry_url}/{search_type}/index.json"
    try:
        req = Request(index_url, headers={"User-Agent": "Scoutica-CLI/0.3.0"})
        resp = urlopen(req, timeout=10)
        index = json.loads(resp.read().decode())
    except Exception as e:
        # Try local examples as fallback
        fallback = os.path.join(script_dir, '..', 'protocol', 'examples')
        if os.path.exists(fallback):
            print(f"  ⚠️  Registry not reachable. Using local examples.")
            print(f"     ({e})")
            print()
            # Build index from local examples
            entries = []
            if search_type == "candidates":
                sample = os.path.join(fallback, 'sample_card')
                if os.path.exists(os.path.join(sample, 'profile.json')):
                    with open(os.path.join(sample, 'profile.json')) as f:
                        p = json.load(f)
                    entries.append({
                        "card_url": sample,
                        "name": p.get("name", ""),
                        "title": p.get("title", ""),
                        "seniority": p.get("seniority", ""),
                        "skills": p.get("skills", []),
                        "availability": p.get("availability", ""),
                    })
            elif search_type == "roles":
                roles_dir = os.path.join(fallback, 'employer_card', 'roles')
                if os.path.exists(roles_dir):
                    for fname in os.listdir(roles_dir):
                        if fname.endswith('.json'):
                            with open(os.path.join(roles_dir, fname)) as f:
                                r = json.load(f)
                            entries.append({
                                "role_url": os.path.join(roles_dir, fname),
                                "title": r.get("title", ""),
                                "hard_skills": r.get("requirements", {}).get("hard_skills", []),
                                "seniority": r.get("requirements", {}).get("seniority", ""),
                                "compensation_range": f"{r.get('compensation', {}).get('base_min', '?')}-{r.get('compensation', {}).get('base_max', '?')} {r.get('compensation', {}).get('currency', '')}",
                                "location": r.get("location", {}).get("type", ""),
                                "status": r.get("status", ""),
                            })
            index = {"entries": entries, "updated": "local"}
        else:
            print(f"  ❌ Could not fetch registry: {e}")
            sys.exit(1)

entries = index.get("entries", [])

# Apply filters
results = []
for entry in entries:
    # Skills filter
    if skills_filter:
        filter_skills = [s.strip().lower() for s in skills_filter.split(",")]
        if search_type == "candidates":
            entry_skills = [s.lower() for s in entry.get("skills", [])]
        else:
            entry_skills = [s.lower() for s in entry.get("hard_skills", [])]
        if not any(fs in entry_skills for fs in filter_skills):
            continue
    
    # Seniority filter
    if seniority_filter:
        if entry.get("seniority", "").lower() != seniority_filter.lower():
            continue
    
    results.append(entry)

if output_json:
    print(json.dumps({"results": results, "count": len(results)}, indent=2))
else:
    if not results:
        print(f"  No {search_type} found matching your criteria.")
        print()
        if skills_filter:
            print(f"  Skills filter: {skills_filter}")
        if seniority_filter:
            print(f"  Seniority filter: {seniority_filter}")
    else:
        print(f"  Found {len(results)} {search_type}:")
        print()
        for i, entry in enumerate(results, 1):
            if search_type == "candidates":
                name = entry.get("name", "Unknown")
                title = entry.get("title", "")
                seniority = entry.get("seniority", "")
                skills = entry.get("skills", [])[:6]
                avail = entry.get("availability", "")
                url = entry.get("card_url", "")
                print(f"  {i}. \033[1m{name}\033[0m — {title}")
                print(f"     Seniority: {seniority} | Availability: {avail}")
                print(f"     Skills: {', '.join(skills)}")
                if url:
                    print(f"     Card: \033[36m{url}\033[0m")
            else:
                title = entry.get("title", "Unknown Role")
                skills = entry.get("hard_skills", [])[:6]
                comp = entry.get("compensation_range", "")
                location = entry.get("location", "")
                status = entry.get("status", "")
                url = entry.get("role_url", "")
                print(f"  {i}. \033[1m{title}\033[0m [{status}]")
                print(f"     Skills: {', '.join(skills)}")
                print(f"     Compensation: {comp} | Location: {location}")
                if url:
                    print(f"     Role: \033[36m{url}\033[0m")
            print()
    print()
SEARCH_SCRIPT
}

# ─── SEND Command (Git-Native Messaging) ─────────────────────────────────────

cmd_send() {
    local recipient_url=""
    local msg_type="opportunity.pitch"
    local role_path=""
    local message_text=""
    local card_dir="."
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type)    msg_type="$2"; shift 2 ;;
            --role)    role_path="$2"; shift 2 ;;
            --message) message_text="$2"; shift 2 ;;
            --card)    card_dir="$2"; shift 2 ;;
            *)         recipient_url="$1"; shift ;;
        esac
    done
    
    if [ -z "$recipient_url" ]; then
        error "No recipient specified."
        echo -e "  ${DIM}Usage: scoutica send <recipient_card_url> --type opportunity.offer --role role.json${NC}"
        exit 1
    fi
    
    header "Send Scoutica Message"
    
    python3 - "$recipient_url" "$msg_type" "$role_path" "$message_text" "$card_dir" <<'SEND_SCRIPT'
import json, sys, os, hashlib
from datetime import datetime, timezone

recipient_url = sys.argv[1]
msg_type = sys.argv[2]
role_path = sys.argv[3]
message_text = sys.argv[4]
card_dir = sys.argv[5]

now = datetime.now(timezone.utc)

# Generate message ID
msg_hash = hashlib.sha256(f"{recipient_url}:{now.isoformat()}".encode()).hexdigest()[:8]
msg_id = f"msg_{msg_hash}"

# Generate conversation ID (or use existing)
conv_hash = hashlib.sha256(f"{recipient_url}:{card_dir}:{msg_type}".encode()).hexdigest()[:8]
conv_id = f"conv_{conv_hash}"

# Build sender info
sender = {"card_url": ""}
try:
    scoutica_file = os.path.join(card_dir, "scoutica.json")
    if os.path.exists(scoutica_file):
        with open(scoutica_file) as f:
            disc = json.load(f)
        sender["card_url"] = disc.get("card_url", "")
    elif os.path.exists(os.path.join(card_dir, "recruiter_profile.json")):
        with open(os.path.join(card_dir, "recruiter_profile.json")) as f:
            rp = json.load(f)
        sender["card_url"] = rp.get("card_url", "")
except Exception:
    pass

# Build payload
payload = {}
if message_text:
    payload["message"] = message_text
if role_path and os.path.exists(role_path):
    payload["role_url"] = role_path
    with open(role_path) as f:
        role = json.load(f)
    if "compensation" in role:
        payload["compensation_summary"] = {
            "base_min": role["compensation"].get("base_min"),
            "base_max": role["compensation"].get("base_max"),
            "currency": role["compensation"].get("currency"),
        }

# Build message envelope
message = {
    "message_id": msg_id,
    "type": msg_type,
    "sender": sender,
    "recipient": recipient_url,
    "conversation_id": conv_id,
    "timestamp": now.strftime("%Y-%m-%dT%H:%M:%SZ"),
    "ttl_hours": 168,
    "transport_used": "git",
    "payload": payload,
}

# Store in local outbox
outbox_dir = os.path.expanduser("~/.scoutica/outbox")
os.makedirs(outbox_dir, exist_ok=True)

msg_file = os.path.join(outbox_dir, f"{msg_id}.json")
