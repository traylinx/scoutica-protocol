        years=$(echo "$profile" | python3 -c "import sys,json; print(json.load(sys.stdin).get('years_experience',''))" 2>/dev/null)
        domains=$(echo "$profile" | python3 -c "import sys,json; p=json.load(sys.stdin); print(', '.join(p.get('primary_domains', p.get('domains',[]))))" 2>/dev/null)
        
        echo -e "${CYAN}║${NC}  ${BOLD}$name${NC}"
        [ -n "$title" ] && echo -e "${CYAN}║${NC}  $title"
        [ -n "$seniority" ] && echo -e "${CYAN}║${NC}  ${DIM}Seniority:${NC} $seniority  ${DIM}|  Experience:${NC} ${years} years"
        [ -n "$domains" ] && echo -e "${CYAN}║${NC}  ${DIM}Domains:${NC} $domains"
        echo -e "${CYAN}╚═══════════════════════════════════════════════════════╝${NC}"
        echo ""
        
        # Skills summary
        local skills_summary
        skills_summary=$(echo "$profile" | python3 -c "
import sys, json
p = json.load(sys.stdin)
s = p.get('skills', {})
parts = []
if s.get('languages'): parts.append(f\"Languages: {', '.join(s['languages'])}\")
if s.get('frameworks'): parts.append(f\"Frameworks: {', '.join(s['frameworks'])}\")
