        fi
    fi
    
    # ── Show rules summary ──
    if [ -n "$rules" ]; then
        local rules_summary
        rules_summary=$(echo "$rules" | python3 -c "
import sys, yaml
try:
    r = yaml.safe_load(sys.stdin)
    if r.get('compensation',{}).get('minimum_base_eur'):
        print(f\"  Minimum salary: {r['compensation']['minimum_base_eur']} EUR\")
