            elif command -v xclip &>/dev/null; then
                cat "$SCOUTICA_HOME/GENERATE_MY_CARD.md" | xclip -selection clipboard
                success "Copied to clipboard! Paste into your AI assistant."
            elif command -v code &>/dev/null; then
                code "$SCOUTICA_HOME/GENERATE_MY_CARD.md"
                success "Opened in VS Code"
