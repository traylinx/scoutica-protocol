cmd_resolve() {
    local url="${1:-}"
    local save_dir="${2:-}"
    
    if [ -z "$url" ] || [ "$url" = "--help" ] || [ "$url" = "-h" ]; then
        echo -e "  ${BOLD}Usage:${NC} scoutica resolve <card-url> [save-to-dir]" >&2
        echo "" >&2
        echo -e "  ${DIM}Fetch and display a Scoutica Protocol Skill Card from any URL.${NC}" >&2
        echo "" >&2
        echo -e "  ${BOLD}Supported URL formats:${NC}" >&2
        echo -e "    ${CYAN}https://github.com/user/repo${NC}" >&2
        echo -e "    ${CYAN}https://raw.githubusercontent.com/user/repo/main/${NC}" >&2
        echo -e "    ${CYAN}https://example.com/path/to/card/${NC}" >&2
        echo "" >&2
        echo -e "  ${BOLD}Examples:${NC}" >&2
        echo -e "    scoutica resolve https://github.com/user/my-card" >&2
        echo -e "    scoutica resolve https://github.com/user/my-card ./local-copy/" >&2
        return 0
    fi
    
    # ── Security: Validate URL ──
    if ! echo "$url" | grep -qE '^https://'; then
        error "Only HTTPS URLs are supported (got: $url)"
        echo -e "  ${DIM}Example: scoutica resolve https://github.com/user/my-card${NC}" >&2
        exit 1
    fi
    
    # Block localhost / private IPs / cloud metadata
    local blocked=false
    blocked=$(python3 -c "
import sys
try:
    from urllib.parse import urlparse
    import ipaddress
    
    url = sys.argv[1]
    parsed = urlparse(url)
    host = parsed.hostname or ''
    
    # Check for localhost, IPv4, IPv6
    private_blocks = [
        ipaddress.ip_network('127.0.0.0/8'),
        ipaddress.ip_network('::1/128'),
        ipaddress.ip_network('fc00::/7'),
        ipaddress.ip_network('fe80::/10'),
        ipaddress.ip_network('10.0.0.0/8'),
        ipaddress.ip_network('172.16.0.0/12'),
        ipaddress.ip_network('192.168.0.0/16'),
        ipaddress.ip_network('169.254.0.0/16'),
        ipaddress.ip_network('0.0.0.0/32'),
    ]
    
    try:
        # Try resolving hostname to IP
        import socket
        addrs = socket.getaddrinfo(host, None)
        for family, _, _, _, sockaddr in addrs:
            ip = ipaddress.ip_address(sockaddr[0])
            for block in private_blocks:
                if ip in block:
                    print('BLOCKED')
                    sys.exit(0)
    except (socket.gaierror, ValueError):
        pass
    
    # Also block if hostname itself is problematic
    host_lower = host.lower()
    if host_lower in ('localhost', 'ip6-localhost', 'ip6-loopback'):
        print('BLOCKED')
        sys.exit(0)
    
    # Block literal IPs in URL
    try:
        ip = ipaddress.ip_address(host)
        for block in private_blocks:
            if ip in block:
                print('BLOCKED')
                sys.exit(0)
    except ValueError:
        pass
except Exception:
    pass
" "$url" 2>/dev/null)
    
    if [ "$blocked" = "BLOCKED" ]; then
        error "Cannot resolve from localhost, private networks, or cloud metadata endpoints"
        exit 1
    fi
    
    # ── Normalize URL to raw base ──
    local base_url=""
    
    if echo "$url" | grep -q "raw.githubusercontent.com"; then
        # Already a raw URL — strip trailing file if present
        base_url=$(echo "$url" | sed 's|/profile\.json$||; s|/rules\.yaml$||; s|/evidence\.json$||; s|/SKILL\.md$||; s|/$||')
    elif echo "$url" | grep -q "github.com"; then
        # Convert github.com URL → raw.githubusercontent.com
        local gh_path
        gh_path=$(echo "$url" | sed 's|https://github.com/||; s|\.git$||; s|/$||')
        local gh_user=$(echo "$gh_path" | cut -d'/' -f1)
        local gh_repo=$(echo "$gh_path" | cut -d'/' -f2)
        local gh_branch="main"
        # Check if URL has a branch/path beyond user/repo
        local extra=$(echo "$gh_path" | cut -d'/' -f3- 2>/dev/null)
        if echo "$extra" | grep -q "^tree/"; then
            gh_branch=$(echo "$extra" | sed 's|^tree/||; s|/.*||')
        fi
        base_url="https://raw.githubusercontent.com/$gh_user/$gh_repo/$gh_branch"
    else
        # Assume direct URL
        base_url=$(echo "$url" | sed 's|/$||')
    fi
    
    header "Resolving Skill Card"
    echo -e "  ${BLUE}→${NC} Fetching from ${DIM}$base_url${NC}"
    echo ""
    
    # ── Try scoutica.json first ──
    local discovery
    discovery=$(curl -sf --connect-timeout 10 --max-time 30 "$base_url/scoutica.json" 2>/dev/null)
    if [ -n "$discovery" ]; then
        echo -e "  ${GREEN}✅${NC} Found scoutica.json (discovery file)"
        local card_url
        card_url=$(echo "$discovery" | python3 -c "import sys,json; print(json.load(sys.stdin).get('card_url',''))" 2>/dev/null)
        if [ -n "$card_url" ] && [ "$card_url" != "$base_url" ]; then
            base_url=$(echo "$card_url" | sed 's|/$||')
            echo -e "  ${DIM}→ Card URL: $base_url${NC}"
        fi
    fi
    
    # ── Fetch card files ──
    local profile="" rules="" evidence="" skill_md=""
    local found=0
    
    profile=$(curl -sf --connect-timeout 10 --max-time 30 "$base_url/profile.json" 2>/dev/null)
    if [ -n "$profile" ]; then
        echo -e "  ${GREEN}📄${NC} profile.json"
        found=$((found + 1))
    else
        echo -e "  ${RED}✗${NC} profile.json ${DIM}(not found)${NC}"
    fi
    
    rules=$(curl -sf --connect-timeout 10 --max-time 30 "$base_url/rules.yaml" 2>/dev/null)
    if [ -n "$rules" ]; then
        echo -e "  ${GREEN}📄${NC} rules.yaml"
