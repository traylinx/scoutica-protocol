        [ -n "$rules" ] && echo "$rules" > "$save_dir/rules.yaml"
        [ -n "$evidence" ] && echo "$evidence" > "$save_dir/evidence.json"
        [ -n "$skill_md" ] && echo "$skill_md" > "$save_dir/SKILL.md"
        [ -n "$discovery" ] && echo "$discovery" > "$save_dir/scoutica.json"
        echo ""
