    echo ""
    echo -e "  ${BOLD}3.${NC} Follow the conversation — the AI will interview you"
    echo -e "     and generate all 4 files"
    echo ""
    echo -e "  ${BOLD}4.${NC} Save the generated files to: ${CYAN}$target_dir/${NC}"
    echo ""
    
    if [ -f "$SCOUTICA_HOME/GENERATE_MY_CARD.md" ]; then
        if confirm "Open GENERATE_MY_CARD.md now?"; then
