# ─── Helpers ──────────────────────────────────────────────────────────────────

header() {
    echo ""
    echo -e "${CYAN}╔═══════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${BOLD}   ⚡ Scoutica Protocol — $1${NC}"
    echo -e "${CYAN}╚═══════════════════════════════════════════════════════╝${NC}"
    echo ""
}

ask() {
    local prompt="$1"
    local default="${2:-}"
    local result=""
    
    if [ -n "$default" ]; then
        echo -ne "  ${BOLD}$prompt${NC} ${DIM}[$default]${NC}: " >&2
        read -r result
        echo "${result:-$default}"
    else
        echo -ne "  ${BOLD}$prompt${NC}: " >&2
        read -r result
        echo "$result"
    fi
}

ask_list() {
    local prompt="$1"
    local hint="${2:-comma-separated}"
    echo -ne "  ${BOLD}$prompt${NC} ${DIM}($hint)${NC}: " >&2
    read -r result
    echo "$result"
}

ask_choice() {
    local prompt="$1"
    shift
    local options=("$@")
    
    echo -e "  ${BOLD}$prompt${NC}" >&2
    for i in "${!options[@]}"; do
        echo -e "    ${CYAN}$((i+1)))${NC} ${options[$i]}" >&2
    done
    while true; do
        echo -ne "  ${BOLD}Choose${NC} ${DIM}[1-${#options[@]}]${NC}: " >&2
        read -r choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#options[@]}" ]; then
            echo "${options[$((choice-1))]}"
            return
        fi
        echo -e "  ${YELLOW}Invalid choice. Try again.${NC}" >&2
    done
}

confirm() {
    local prompt="$1"
    echo -ne "  ${BOLD}$prompt${NC} ${DIM}[y/N]${NC}: "
    read -r answer
    [[ "$answer" =~ ^[Yy] ]]
}

success() {
    echo -e "  ${GREEN}✅ $1${NC}"
}

warn() {
    echo -e "  ${YELLOW}⚠️  $1${NC}"
}

error() {
    echo -e "  ${RED}❌ $1${NC}"
}

# Convert comma-separated string to JSON array (safely escaped)
to_json_array() {
    local input="$1"
    python3 -c "
import json, sys
items = [s.strip() for s in sys.argv[1].split(',') if s.strip()]
print(json.dumps(items))
" "$input"
}

# Convert comma-separated string to YAML list
to_yaml_list() {
    local input="$1"
    local indent="${2:-    }"
    
    IFS=',' read -ra items <<< "$input"
    for item in "${items[@]}"; do
        item=$(echo "$item" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        if [ -n "$item" ]; then
            echo "${indent}- \"$item\""
        fi
    done
}

# ─── INIT Command ─────────────────────────────────────────────────────────────

cmd_init() {
    local target_dir="${1:-.}"
    local use_ai=false
    
    # Parse flags
    for arg in "$@"; do
        case "$arg" in
            --ai) use_ai=true ;;
            *) target_dir="$arg" ;;
        esac
    done
    
    if $use_ai; then
        cmd_init_ai "$target_dir"
        return
    fi
    
    header "Create Your Skill Card"
    
    echo -e "  ${DIM}Answer the questions below to generate your Scoutica Protocol Skill Card.${NC}"
    echo -e "  ${DIM}Press Enter to skip optional fields or accept defaults.${NC}"
    echo ""
    
    # ── Section 1: Identity ──
    echo -e "  ${MAGENTA}━━━ 👤 Identity ━━━${NC}"
    echo ""
    local name=$(ask "Your professional name")
    local title=$(ask "Professional title" "Software Engineer")
    
    local seniority=$(ask_choice "Seniority level" \
        "entry" "junior" "mid" "senior" "lead" "manager" "director" "executive")
    
    local years=$(ask "Years of experience" "5")
    
    local availability=$(ask_choice "Availability" \
        "immediately" "in_2_weeks" "in_4_weeks" "in_8_weeks" "not_looking")
    
