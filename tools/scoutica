# ─── DELIVER Command (Push Pending Messages) ────────────────────────────────

cmd_deliver() {
    header "Deliver Pending Messages"
    
    python3 - <<'DELIVER_SCRIPT'
import json, sys, os, shutil

pending_dir = os.path.expanduser("~/.scoutica/pending_delivery")
delivered_dir = os.path.expanduser("~/.scoutica/delivered")
os.makedirs(delivered_dir, exist_ok=True)

if not os.path.exists(pending_dir):
    print("  📭 No pending messages to deliver.")
    sys.exit(0)

# Count pending
pending = []
for root, dirs, files in os.walk(pending_dir):
    for fname in files:
        if fname.endswith('.json'):
            pending.append(os.path.join(root, fname))

if not pending:
    print("  📭 No pending messages to deliver.")
    sys.exit(0)

print(f"  📤 {len(pending)} message(s) pending delivery:")
print()

for filepath in pending:
    try:
        with open(filepath) as f:
            msg = json.load(f)
        
        msg_id = msg.get("message_id", "unknown")
        msg_type = msg.get("type", "unknown")
        recipient = msg.get("recipient", "unknown")
        
        # Get recipient hash from directory name
        recipient_dir = os.path.basename(os.path.dirname(filepath))
        
        print(f"  📨 {msg_id}")
        print(f"     Type: {msg_type}")
        print(f"     To: {recipient}")
        
        # Move to delivered
        dest_dir = os.path.join(delivered_dir, recipient_dir)
        os.makedirs(dest_dir, exist_ok=True)
        dest = os.path.join(dest_dir, os.path.basename(filepath))
        shutil.move(filepath, dest)
        
        print(f"     ✅ Marked as delivered")
        print()
        
    except Exception as e:
        print(f"     ❌ Error: {e}")
        print()

# Clean empty dirs
for dirpath, dirnames, filenames in os.walk(pending_dir, topdown=False):
    if not dirnames and not filenames and dirpath != pending_dir:
        os.rmdir(dirpath)

print(f"  ────────────────────────────────────────")
print(f"  {len(pending)} message(s) delivered.")
print(f"  Delivery log: {delivered_dir}")
print()
print(f"  ℹ️  In production, delivery means:")
print(f"     • Git transport: open PR on traylinx/scoutica-registry")
print(f"     • Nostr: publish NIP-44 encrypted event to relays")
print(f"     • Webhook: POST to recipient's agent_endpoint")
DELIVER_SCRIPT
    
    echo ""
}

# ─── REGISTER Command (Generate Registry Entry) ──────────────────────────────

cmd_register() {
    local card_dir="${1:-.}"
    local card_type="candidate"
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type) card_type="$2"; shift 2 ;;
            *)      card_dir="$1"; shift ;;
        esac
    done
    
    header "Generate Registry Entry"
    
    python3 - "$card_dir" "$card_type" <<'REGISTER_SCRIPT'
import json, sys, os
from datetime import datetime, timezone

card_dir = sys.argv[1]
card_type = sys.argv[2]

now = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

if card_type == "candidate":
    profile_path = os.path.join(card_dir, "profile.json")
    scoutica_path = os.path.join(card_dir, "scoutica.json")
    
    if not os.path.exists(profile_path):
        print(f"  ❌ No profile.json found in {card_dir}")
        sys.exit(1)
    
    with open(profile_path) as f:
        profile = json.load(f)
    
    card_url = ""
    transport = "git"
    if os.path.exists(scoutica_path):
        with open(scoutica_path) as f:
            disc = json.load(f)
        card_url = disc.get("card_url", "")
        transport = disc.get("transport", {}).get("preferred", "git") if isinstance(disc.get("transport"), dict) else "git"
    
    entry = {
        "card_url": card_url,
        "name": profile.get("name", ""),
        "title": profile.get("title", ""),
        "seniority": profile.get("seniority", ""),
        "skills": (profile.get("skills", []) + profile.get("tools_and_platforms", []))[:10],
        "domains": profile.get("primary_domains", profile.get("domains", [])),
        "availability": profile.get("availability", ""),
        "entity_type": profile.get("entity_type", "human"),
        "transport": transport,
        "updated": datetime.now().strftime("%Y-%m-%d"),
        "registered_at": now,
    }
    
    print(f"  ✅ Registry entry generated for: {entry['name']}")

elif card_type == "role" or card_type == "roles":
    roles_dir = os.path.join(card_dir, "roles")
    recruiter_path = os.path.join(card_dir, "recruiter_profile.json")
    
    recruiter_url = ""
    if os.path.exists(recruiter_path):
        with open(recruiter_path) as f:
            rp = json.load(f)
        recruiter_url = rp.get("card_url", "")
    
    entries = []
    if os.path.exists(roles_dir):
        for fname in sorted(os.listdir(roles_dir)):
            if not fname.endswith('.json'):
                continue
            with open(os.path.join(roles_dir, fname)) as f:
                role = json.load(f)
            
            comp = role.get("compensation", {})
            comp_range = f"{comp.get('base_min', '?')}-{comp.get('base_max', '?')} {comp.get('currency', '')}"
            
            entry = {
                "role_url": f"{recruiter_url.rsplit('/', 1)[0]}/roles/{fname}" if recruiter_url else fname,
                "recruiter_card_url": recruiter_url,
                "title": role.get("title", ""),
                "hard_skills": role.get("requirements", {}).get("hard_skills", []),
                "seniority": role.get("requirements", {}).get("seniority", ""),
                "compensation_range": comp_range,
                "location": role.get("location", {}).get("type", ""),
                "engagement_type": role.get("engagement", {}).get("type", ""),
                "status": role.get("status", "active"),
                "posted_at": role.get("posted_at", now),
                "expires_at": role.get("expires_at", ""),
                "registered_at": now,
            }
            entries.append(entry)
            print(f"  ✅ Registry entry for role: {entry['title']}")
    else:
        print(f"  ❌ No roles/ directory found in {card_dir}")
        sys.exit(1)
    
    entry = entries  # multiple entries for roles

# Save to local staging
staging_dir = os.path.expanduser("~/.scoutica/registry_staging")
os.makedirs(staging_dir, exist_ok=True)

if card_type == "candidate":
    staging_file = os.path.join(staging_dir, "candidate_entry.json")
    with open(staging_file, "w") as f:
        json.dump(entry, f, indent=2, ensure_ascii=False)
        f.write("\n")
else:
    staging_file = os.path.join(staging_dir, "role_entries.json")
    with open(staging_file, "w") as f:
        json.dump(entries, f, indent=2, ensure_ascii=False)
        f.write("\n")

print()
print(f"  📋 Staged at: {staging_file}")
print()
print(f"  📋 Next steps:")
print(f"     1. Fork traylinx/scoutica-registry")
if card_type == "candidate":
    print(f"     2. Add your entry to candidates/index.json")
else:
    print(f"     2. Add your entries to roles/index.json")
print(f"     3. Open a Pull Request")
print(f"     4. The CI will validate your entry against the schema")
print()
print(f"  Entry preview:")
print(json.dumps(entry if card_type == "candidate" else entries, indent=2))
REGISTER_SCRIPT
    
    echo ""
}

# ─── Main Router ──────────────────────────────────────────────────────────────

main() {
    local command="${1:-help}"
    shift 2>/dev/null || true
    
    case "$command" in
        init)       cmd_init "$@" ;;
        scan)       cmd_scan "$@" ;;
        resolve)    cmd_resolve "$@" ;;
        validate)   cmd_validate "$@" ;;
        publish)    cmd_publish "$@" ;;
        info)       cmd_info "$@" ;;
        preview)    cmd_preview "$@" ;;
        update)     cmd_update "$@" ;;
        doctor)     cmd_doctor "$@" ;;
        status)     cmd_status "$@" ;;
        logs)       cmd_logs "$@" ;;
        org)        cmd_org "$@" ;;
        role)       cmd_role "$@" ;;
        evaluate)   cmd_evaluate "$@" ;;
        jobs)       cmd_jobs "$@" ;;
        send)       cmd_send "$@" ;;
        inbox)      cmd_inbox "$@" ;;
        reply)      cmd_reply "$@" ;;
        deliver)    cmd_deliver "$@" ;;
        register)   cmd_register "$@" ;;
        identity)   cmd_identity "$@" ;;
        help|--help|-h)  cmd_help ;;
        version|--version|-v) echo "scoutica v$VERSION" ;;
        *)
            error "Unknown command: $command"
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"



