cmd_init_ai() {
    local target_dir="${1:-.}"
    
    header "AI-Powered Card Creation"
    
    echo -e "  The easiest way to create your card with AI:"
    echo ""
    echo -e "  ${BOLD}1.${NC} Copy the contents of this file:"
