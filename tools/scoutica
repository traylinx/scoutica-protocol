    evidence=$(curl -sf --connect-timeout 10 --max-time 30 "$base_url/evidence.json" 2>/dev/null)
    if [ -n "$evidence" ]; then
        echo -e "  ${GREEN}📄${NC} evidence.json"
        found=$((found + 1))
    else
        echo -e "  ${RED}✗${NC} evidence.json ${DIM}(not found)${NC}"
    fi
    
    skill_md=$(curl -sf --connect-timeout 10 --max-time 30 "$base_url/SKILL.md" 2>/dev/null)
    if [ -n "$skill_md" ]; then
        echo -e "  ${GREEN}📄${NC} SKILL.md"
        found=$((found + 1))
    else
        echo -e "  ${RED}✗${NC} SKILL.md ${DIM}(not found)${NC}"
    fi
    
    echo ""
    
    if [ "$found" -eq 0 ]; then
        error "No Scoutica Protocol card files found at $base_url"
        echo -e "  ${DIM}Make sure the URL points to a repo with profile.json at the root.${NC}" >&2
        exit 1
    fi
    
    echo -e "  ${GREEN}✅${NC} Found ${BOLD}$found/4${NC} card files"
    echo ""
    
    # ── Display card summary ──
    if [ -n "$profile" ]; then
        echo -e "${CYAN}╔═══════════════════════════════════════════════════════╗${NC}"
        
        local name title seniority years domains
        name=$(echo "$profile" | python3 -c "import sys,json; print(json.load(sys.stdin).get('name','Unknown'))" 2>/dev/null)
        title=$(echo "$profile" | python3 -c "import sys,json; print(json.load(sys.stdin).get('title',''))" 2>/dev/null)
