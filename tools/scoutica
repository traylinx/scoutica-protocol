cmd_org_verify() {
    local domain=""
    
    # Parse --domain flag
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --domain) domain="$2"; shift 2 ;;
            *) domain="$1"; shift ;;
        esac
    done
    
    if [ -z "$domain" ]; then
        # Try to read from recruiter_profile.json
        if [ -f "recruiter_profile.json" ]; then
            domain=$(python3 -c "import json; print(json.load(open('recruiter_profile.json'))['organization']['domain'])" 2>/dev/null)
        fi
    fi
    
    if [ -z "$domain" ]; then
        error "No domain specified. Usage: scoutica org verify --domain example.com"
        exit 1
    fi
    
    header "Verify Domain Ownership"
    
    # Generate verification hash
    local org_name=""
    if [ -f "recruiter_profile.json" ]; then
        org_name=$(python3 -c "import json; print(json.load(open('recruiter_profile.json'))['organization']['name'])" 2>/dev/null || echo "")
    fi
    
    local verify_input="${org_name}.${domain}.0.3.0"
    local verify_hash=$(printf '%s' "$verify_input" | shasum -a 256 | awk '{print $1}' | cut -c1-32)
    local record_value="scoutica-verify=v1:${verify_hash}"
    
    echo -e "  ${BOLD}Step 1:${NC} Add this DNS TXT record to your domain:"
    echo ""
    echo -e "    ${BOLD}Name:${NC}   _scoutica.${domain}"
    echo -e "    ${BOLD}Type:${NC}   TXT"
    echo -e "    ${BOLD}Value:${NC}  ${CYAN}${record_value}${NC}"
    echo ""
    echo -e "  ${BOLD}Step 2:${NC} Wait for DNS propagation (usually 1-5 minutes)."
    echo ""
    
    if confirm "Check DNS now?"; then
        echo -e "  ${DIM}Checking _scoutica.${domain}...${NC}"
        
        local dns_result
        dns_result=$(dig +short TXT "_scoutica.${domain}" 2>/dev/null | tr -d '"' || echo "")
        
        if echo "$dns_result" | grep -q "$record_value"; then
            success "Domain verified! ✅"
            
            # Update recruiter_profile.json
            if [ -f "recruiter_profile.json" ]; then
                python3 -c "
import json
from datetime import datetime, timezone
with open('recruiter_profile.json') as f:
    data = json.load(f)
data['organization']['domain_verified'] = True
data['organization']['verified_at'] = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')
data['updated_at'] = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')
with open('recruiter_profile.json', 'w') as f:
    json.dump(data, f, indent=2, ensure_ascii=False)
    f.write('\n')
" 2>/dev/null && success "Updated recruiter_profile.json with verification timestamp"
            fi
        else
            warn "TXT record not found yet."
            echo -e "  ${DIM}DNS propagation can take up to 48 hours.${NC}"
            echo -e "  ${DIM}Run this command again later: scoutica org verify --domain ${domain}${NC}"
        fi
    else
        echo -e "  ${DIM}When ready, run: scoutica org verify --domain ${domain}${NC}"
    fi
    echo ""
}

cmd_org_publish() {
    local card_dir="${1:-.}"
    
    header "Publish Employer Card to GitHub"
    
    # Check for recruiter_profile.json
    if [ ! -f "$card_dir/recruiter_profile.json" ]; then
        error "No Employer Card found in $card_dir"
        echo -e "  ${DIM}Run 'scoutica org init' first.${NC}"
        exit 1
    fi
    
    if ! command -v git &>/dev/null; then
        error "Git is not installed."
        exit 1
    fi
    
    if [ -d "$card_dir/.git" ]; then
        (
            cd "$card_dir"
            # Stage known employer card files
            local card_files=(recruiter_profile.json hiring_rules.yaml)
            for cf in "${card_files[@]}"; do
                [ -f "$cf" ] && git add "$cf" 2>/dev/null
            done
            [ -d "roles" ] && git add roles/ 2>/dev/null
            
            local changes
            changes=$(git status -s 2>/dev/null | grep -E 'recruiter_profile|hiring_rules|roles/') || true
            
            if [ -z "$changes" ]; then
                echo -e "  ${GREEN}✅${NC} Employer Card is already up to date!"
                local origin_url=$(git remote get-url origin 2>/dev/null || echo "")
                if [ -n "$origin_url" ]; then
                    echo -e "  ${DIM}Live at:${NC} $(echo "$origin_url" | sed 's/\.git$//')"
                fi
                return 0
            fi
            
            echo -e "  ${BOLD}Publishing these changes:${NC}"
            echo "$changes" | while read -r line; do
                echo -e "    ${CYAN}$line${NC}"
            done
            echo ""
            
            local msg="Update Scoutica Employer Card — $(date +%Y-%m-%d)"
            git commit -m "$msg" >/dev/null 2>&1
            
            if git remote -v | grep -q "origin"; then
                echo -e "  ${DIM}Pushing to GitHub...${NC}"
                if git push origin "$(git branch --show-current)" >/dev/null 2>&1; then
                    success "Successfully published to GitHub!"
                    local origin_url=$(git remote get-url origin)
                    local clean_url=$(echo "$origin_url" | sed 's/\.git$//')
                    echo -e "  ${BOLD}View:${NC} $clean_url"
                else
                    error "Push failed. Check your remote or permissions."
                fi
            else
                warn "No remote 'origin' configured."
                echo -e "  ${DIM}Run: git remote add origin https://github.com/ORG/.scoutica.git${NC}"
            fi
        )
    else
        warn "Not a git repository."
        echo -e "  ${DIM}Initialize with: git init && git remote add origin ...${NC}"
    fi
    echo ""
}

# ─── ROLE Command (Job Postings) ──────────────────────────────────────────────

cmd_role() {
