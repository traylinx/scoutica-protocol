    # ── Smart caching: skip if card unchanged and URL still valid ──
    if [ "$force" = false ]; then
        local current_card_hash=$(_compute_card_hash "$target_dir")
        local stored_card_hash=$(_read_state "preview.card_hash")
        local stored_url=$(_read_state "preview.url")
        local stored_expires=$(_read_state "preview.expires_at")
        
        if [ -n "$stored_card_hash" ] && [ "$current_card_hash" = "$stored_card_hash" ] && [ -n "$stored_url" ] && [ -n "$stored_expires" ]; then
            # Check if URL is still valid (not expired)
