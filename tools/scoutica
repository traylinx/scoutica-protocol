# ─── State Management ─────────────────────────────────────────────────────────

_compute_source_hash() {
    local dir="$1"
    local hash_input=""
    for file in "$dir"/*; do
        [ -f "$file" ] || continue
        local bn=$(basename "$file")
        case "$bn" in
            profile.json|rules.yaml|evidence.json|SKILL.md|scoutica_prompt.txt|scoutica.json) continue ;;
        esac
        local ext="${bn##*.}"
        ext=$(echo "$ext" | tr '[:upper:]' '[:lower:]')
        case "$ext" in
            md|txt|json|yaml|yml|csv|html|htm|pdf|docx)
                hash_input+=$(shasum -a 256 "$file" 2>/dev/null | awk '{print $1}')
                ;;
        esac
    done
    echo -n "$hash_input" | shasum -a 256 | awk '{print $1}'
}

_compute_card_hash() {
    local dir="$1"
    local hash_input=""
    for f in profile.json rules.yaml evidence.json SKILL.md; do
        [ -f "$dir/$f" ] && hash_input+=$(shasum -a 256 "$dir/$f" 2>/dev/null | awk '{print $1}')
    done
    echo -n "$hash_input" | shasum -a 256 | awk '{print $1}'
}

_read_state() {
    local key="$1"
    if [ -f "$STATE_FILE" ] && command -v python3 &>/dev/null; then
        python3 -c "
import json, sys
try:
    with open('$STATE_FILE') as f:
        d = json.load(f)
    keys = '$key'.split('.')
    for k in keys:
        d = d[k]
    print(d)
except Exception as e:
    print('', file=sys.stderr)
" 2>/dev/null
    fi
}

_write_state() {
    mkdir -p "$STATE_DIR"
    local source_hash="$1" provider="$2" source_files="$3"
    local now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    
    # Read existing state or start fresh — use temp file to avoid heredoc injection
    local tmp_existing=$(mktemp /tmp/scoutica_state.XXXXXX)
    if [ -f "$STATE_FILE" ]; then
        cp "$STATE_FILE" "$tmp_existing"
    else
        echo '{}' > "$tmp_existing"
    fi
    
    python3 - "$tmp_existing" "$source_hash" "$now" "$source_files" "$provider" "$STATE_FILE" <<'WRITESTATE'
import json, sys
existing_file, source_hash, now, source_files, provider, state_file = sys.argv[1:7]
try:
    with open(existing_file) as f:
        state = json.load(f)
except Exception:
    state = {}
state['schema_version'] = '0.1.0'
state['card'] = {
    'source_hash': source_hash,
    'generated_at': now,
    'source_files': [s for s in source_files.split(',') if s],
    'provider': provider
}
if 'preview' not in state:
    state['preview'] = {}
with open(state_file, 'w') as f:
    json.dump(state, f, indent=2)
WRITESTATE
    rm -f "$tmp_existing"
}

_write_preview_state() {
    mkdir -p "$STATE_DIR"
    local url="$1" card_hash="$2"
    local now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    local expires=$(python3 -c "from datetime import datetime,timedelta,timezone;print((datetime.now(timezone.utc)+timedelta(hours=24)).strftime('%Y-%m-%dT%H:%M:%SZ'))" 2>/dev/null || echo "")
    
    # Use temp file to avoid heredoc injection
    local tmp_existing=$(mktemp /tmp/scoutica_state.XXXXXX)
    if [ -f "$STATE_FILE" ]; then
        cp "$STATE_FILE" "$tmp_existing"
    else
        echo '{}' > "$tmp_existing"
    fi
    
    python3 - "$tmp_existing" "$url" "$now" "$expires" "$card_hash" "$STATE_FILE" <<'WRITEPREVIEW'
import json, sys
existing_file, url, now, expires, card_hash, state_file = sys.argv[1:7]
try:
    with open(existing_file) as f:
        state = json.load(f)
except Exception:
    state = {}
state['preview'] = {
    'url': url,
    'published_at': now,
    'expires_at': expires,
    'card_hash': card_hash
}
with open(state_file, 'w') as f:
    json.dump(state, f, indent=2)
WRITEPREVIEW
    rm -f "$tmp_existing"
}

# ─── Name Slugify ─────────────────────────────────────────────────────────────

_slugify_name() {
    local name="$1"
    echo "$name" | tr '[:upper:]' '[:lower:]' | \
        sed 's/[^a-z0-9 ]//g' | \
        sed 's/  */ /g' | \
        sed 's/ /-/g' | \
        sed 's/--*/-/g' | \
        sed 's/^-//;s/-$//'
}

# ─── Global Registry ─────────────────────────────────────────────────────────

_register_card() {
    local card_dir="$1" event="$2"
    shift 2
    local extra_json="${1:-{}}"
    
    mkdir -p "$SCOUTICA_HOME"
    
    # Read name and title from profile.json if available
    local name="" title=""
    if [ -f "$card_dir/profile.json" ] && command -v python3 &>/dev/null; then
        name=$(python3 -c "import json;d=json.load(open('$card_dir/profile.json'));print(d.get('name',''))" 2>/dev/null || echo "")
        title=$(python3 -c "import json;d=json.load(open('$card_dir/profile.json'));print(d.get('title',''))" 2>/dev/null || echo "")
    fi
    
    python3 << 'REGSCRIPT' - "$REGISTRY_FILE" "$card_dir" "$event" "$name" "$title" "$extra_json"
import json, os, sys
from datetime import datetime, timezone

registry_file = sys.argv[1]
card_dir = os.path.abspath(sys.argv[2])
event = sys.argv[3]
now = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
name = sys.argv[4]
title = sys.argv[5]

try:
    extra = json.loads(sys.argv[6])
except:
    extra = {}

# Load existing registry
try:
    with open(registry_file) as f:
        registry = json.load(f)
except:
    registry = {"schema_version": "0.1.0", "cards": {}}

if "cards" not in registry:
    registry["cards"] = {}

# Get or create card entry
card = registry["cards"].get(card_dir, {
    "name": name,
    "title": title,
    "card_dir": card_dir,
    "source_dir": None,
    "github_url": None,
    "preview_url": None,
    "created_at": now,
    "last_scanned": None,
    "last_published": None,
    "last_previewed": None,
    "provider": None,
    "scan_count": 0,
    "exists": True,
    "history": []
})

# Update fields
if name: card["name"] = name
if title: card["title"] = title
card["exists"] = os.path.isdir(card_dir)

history_entry = {"event": event, "at": now}

if event == "scan" or event == "rescan":
    card["last_scanned"] = now
    card["scan_count"] = card.get("scan_count", 0) + 1
    if extra.get("provider"): card["provider"] = extra["provider"]
    if extra.get("source_dir"): card["source_dir"] = extra["source_dir"]
    history_entry["provider"] = extra.get("provider", "unknown")
elif event == "publish":
    card["last_published"] = now
    if extra.get("github_url"): card["github_url"] = extra["github_url"]
    history_entry["github_url"] = extra.get("github_url", "")
elif event == "preview":
    card["last_previewed"] = now
    if extra.get("preview_url"): card["preview_url"] = extra["preview_url"]
    history_entry["preview_url"] = extra.get("preview_url", "")

card["history"].append(history_entry)
# Keep last 50 history entries
card["history"] = card["history"][-50:]

registry["cards"][card_dir] = card

with open(registry_file, "w") as f:
    json.dump(registry, f, indent=2)
REGSCRIPT
}

_get_last_card() {
    if [ ! -f "$REGISTRY_FILE" ] || ! command -v python3 &>/dev/null; then
        echo ""
        return
    fi
    python3 -c "
import json
try:
    with open('$REGISTRY_FILE') as f:
        reg = json.load(f)
    cards = reg.get('cards', {})
    if not cards:
        print('')
    else:
        latest = max(cards.values(), key=lambda c: c.get('last_scanned') or c.get('created_at') or '')
        print(latest.get('card_dir', ''))
except:
    print('')
" 2>/dev/null
}

_resolve_card_dir() {
    local explicit="${1:-}"
    
    # 1. Explicit argument passed
    if [ -n "$explicit" ] && [ -f "$explicit/profile.json" ]; then
        echo "$explicit"
        return 0
    fi
    
    # 2. CWD has a card
    if [ -f "./profile.json" ]; then
        echo "."
        return 0
    fi
    
    # 3. CWD is inside a card subfolder (parent has profile.json)
    if [ -f "../profile.json" ]; then
        echo ".."
        return 0
    fi
    
    # 4. Check global registry for last known card
    local last_card=$(_get_last_card)
    if [ -n "$last_card" ] && [ -d "$last_card" ] && [ -f "$last_card/profile.json" ]; then
        echo -e "  ${DIM}Using last known card: $last_card${NC}" >&2
        echo "$last_card"
        return 0
    fi
    
    # 5. Registry knows a card but folder is gone
    if [ -n "$last_card" ] && [ ! -d "$last_card" ]; then
        echo -e "  ${YELLOW}⚠️  Last known card folder was deleted: $last_card${NC}" >&2
        # Check if there's a GitHub URL stored
        local gh_url
        gh_url=$(python3 -c "
import json
try:
    with open('$REGISTRY_FILE') as f:
        reg = json.load(f)
    card = reg['cards'].get('$last_card', {})
    print(card.get('github_url', '') or '')
except: print('')
" 2>/dev/null)
        if [ -n "$gh_url" ]; then
            echo -e "  ${DIM}Last published to: $gh_url${NC}" >&2
        fi
        echo -e "  ${DIM}Run 'scoutica scan' to regenerate your card.${NC}" >&2
        return 1
    fi
    
    # 6. Nothing found
    return 1
}

# ─── SCAN Command ─────────────────────────────────────────────────────────────

cmd_scan() {
    local source_dir=""
    local output_dir=""
    local explicit_output=false
    local provider=""
    
    local force=false
    
    # Parse flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --output|-o) output_dir="$2"; explicit_output=true; shift 2 ;;
            --with|-w) provider="$2"; shift 2 ;;
            --force|-f) force=true; shift ;;
            --clipboard|-c) provider="clipboard"; shift ;;
            --help|-h) 
                echo -e "  ${BOLD}Usage:${NC} scoutica scan <docs-folder> [options]" >&2
                echo "" >&2
                echo -e "  ${DIM}Reads your documents and generates a Skill Card using a local AI CLI.${NC}" >&2
                echo -e "  ${DIM}Your data never leaves your machine.${NC}" >&2
                echo "" >&2
                echo -e "  ${BOLD}Options:${NC}" >&2
                echo -e "    --output, -o <dir>    Output directory for card files (default: .)" >&2
                echo -e "    --with, -w <cli>      AI CLI to use: gemini, claude, ollama (auto-detected)" >&2
                echo -e "    --force, -f            Force regeneration even if sources unchanged" >&2
                echo -e "    --clipboard, -c       Just copy the prompt to clipboard (no AI call)" >&2
                echo "" >&2
                echo -e "  ${BOLD}Supported AI CLIs (auto-detected):${NC}" >&2
                echo -e "    ${CYAN}gemini${NC}     Google Gemini CLI    ${DIM}(github.com/google-gemini/gemini-cli)${NC}" >&2
                echo -e "    ${CYAN}claude${NC}     Claude Code CLI      ${DIM}(github.com/anthropics/claude-code)${NC}" >&2
                echo -e "    ${CYAN}codex${NC}      OpenAI Codex CLI     ${DIM}(github.com/openai/codex)${NC}" >&2
                echo -e "    ${CYAN}vibe${NC}       Mistral Vibe CLI     ${DIM}(github.com/mistralai/mistral-vibe)${NC}" >&2
                echo -e "    ${CYAN}opencode${NC}   OpenCode CLI         ${DIM}(github.com/opencode-ai/opencode)${NC}" >&2
                echo -e "    ${CYAN}ollama${NC}     Ollama (local LLM)   ${DIM}(ollama.com)${NC}" >&2
                echo -e "    ${CYAN}ail${NC}        switchAILocal        ${DIM}(github.com/traylinx/switchAILocal)${NC}" >&2
                echo -e "    ${CYAN}openclaw${NC}   OpenClaw             ${DIM}(github.com/openclaw/openclaw)${NC}" >&2
                echo "" >&2
                echo -e "  ${BOLD}Examples:${NC}" >&2
                echo -e "    scoutica scan ~/CV/                      ${DIM}# auto-detect CLI${NC}" >&2
                echo -e "    scoutica scan ~/CV/ --with gemini         ${DIM}# use Gemini CLI${NC}" >&2
                echo -e "    scoutica scan ~/CV/ --with codex          ${DIM}# use OpenAI Codex${NC}" >&2
                echo -e "    scoutica scan ~/CV/ --with ail            ${DIM}# use switchAILocal${NC}" >&2
                echo -e "    scoutica scan ~/CV/ --clipboard           ${DIM}# copy prompt to clipboard${NC}" >&2
                return 0
                ;;
            *) 
                if [ -z "$source_dir" ]; then
                    source_dir="$1"
                fi
                shift
                ;;
        esac
    done
    
    if [ -z "$source_dir" ]; then
        error "Usage: scoutica scan <docs-folder> [--output <dir>] [--with <provider>]"
        echo "" >&2
        echo -e "  ${DIM}Example (current folder):${NC}  scoutica scan . --with default" >&2
        
        # Detect available providers for the error message
        local available=""
        for cli in gemini claude codex vibe opencode ollama ail; do
            if command -v "$cli" >/dev/null 2>&1; then
                available="$available $cli"
            fi
        done
        if ! command -v "ail" >/dev/null 2>&1 && curl -sf http://localhost:18080/health &>/dev/null 2>&1; then
            available="$available ail"
        fi
        
        if [ -n "$available" ]; then
            local first=$(echo $available | awk '{print $1}')
            echo -e "  ${DIM}Example (specific AI):${NC}     scoutica scan ~/CV/ --with $first" >&2
            echo "" >&2
            echo -e "  ${BOLD}Installed AI providers you can use:${NC}${CYAN}$available${NC}" >&2
        else
            echo -e "  ${DIM}Example (clipboard):${NC}       scoutica scan ~/CV/ --clipboard" >&2
            echo "" >&2
            echo -e "  ${YELLOW}⚠ No AI CLIs installed. Use --clipboard mode.${NC}" >&2
        fi
        echo "" >&2
        exit 1
    fi
    
    if [ ! -d "$source_dir" ]; then
        error "Directory not found: $source_dir"
        exit 1
    fi
    
    # If no explicit --output, default to source_dir (will be redirected to subfolder after AI generation)
    if [ -z "$output_dir" ]; then
        output_dir="$source_dir"
    fi
    
    header "AI-Powered Card Generation"
    
    # ── Check for existing card files ──
    local existing_files=()
    for f in profile.json rules.yaml evidence.json SKILL.md; do
        [ -f "$output_dir/$f" ] && existing_files+=("$f")
    done
    
    if [ ${#existing_files[@]} -gt 0 ]; then
        warn "Existing card files found in $output_dir:"
        for f in "${existing_files[@]}"; do
            echo -e "    ${YELLOW}•${NC} $f" >&2
        done
        echo "" >&2
        
        # Auto-backup
        local backup_dir="$output_dir/.backup/$(date +%Y%m%d_%H%M%S)"
        mkdir -p "$backup_dir"
        for f in "${existing_files[@]}"; do
            cp "$output_dir/$f" "$backup_dir/$f"
        done
        [ -d "$output_dir/rules" ] && cp -r "$output_dir/rules" "$backup_dir/rules" 2>/dev/null
        
        success "Backed up existing files to .backup/"
        echo -e "  ${DIM}Scan will overwrite with AI-generated versions.${NC}" >&2
        echo "" >&2
    fi
    
    # ── Symlink protection ──
    for f in profile.json rules.yaml evidence.json SKILL.md; do
        if [ -L "$output_dir/$f" ]; then
            error "Refusing to overwrite symlink: $output_dir/$f"
            exit 1
        fi
    done
    
    # ── Step 0: Check if source docs have changed ──
    # ── Initialize logging ──
    _scan_log_init
    _scan_log "INIT" "source_dir=$source_dir, force=$force, provider=${provider:-auto}"
    
    local current_hash=$(_compute_source_hash "$source_dir")
    local stored_hash=$(_read_state "card.source_hash")
    _scan_log "HASH" "current=$current_hash, stored=$stored_hash"
    
    if [ "$force" = false ] && [ -n "$stored_hash" ] && [ "$current_hash" = "$stored_hash" ]; then
        # Check that all card files actually exist
        local all_exist=true
        for f in profile.json rules.yaml evidence.json SKILL.md; do
            [ ! -f "$output_dir/$f" ] && all_exist=false
        done
        
        if [ "$all_exist" = true ]; then
            success "Card is up to date (source documents unchanged)"
            echo -e "  ${DIM}Use --force to regenerate anyway${NC}" >&2
            echo ""
            
            # Auto-chain to preview if desired
            echo -e "  ${BOLD}What to do next:${NC}\n"
            echo -e "  ${CYAN}•${NC} ${CYAN}scoutica preview${NC}   ${DIM}Deploy a live web preview${NC}"
            echo -e "  ${CYAN}•${NC} ${CYAN}scoutica validate${NC}  ${DIM}Check your card for schema errors${NC}"
            echo -e "  ${CYAN}•${NC} ${CYAN}scoutica scan --force${NC} ${DIM}Regenerate from scratch${NC}"
            echo ""
            return 0
        fi
    fi
    
    # ── Step 1: Read all documents ──
    _scan_log "EXTRACT" "scanning directory: $source_dir"
    echo -e "  ${BLUE}→${NC} Scanning ${BOLD}$source_dir${NC}..."
    echo ""
    
    local all_text=""
    local file_count=0
    
    for file in "$source_dir"/*; do
        [ -f "$file" ] || continue
        local basename=$(basename "$file")
        
        # Skip generated card files (in case source == output dir)
        case "$basename" in
            profile.json|rules.yaml|evidence.json|SKILL.md|scoutica_prompt.txt) continue ;;
        esac
        
        local ext="${basename##*.}"
        ext=$(echo "$ext" | tr '[:upper:]' '[:lower:]')
        
        case "$ext" in
            md|txt|json|yaml|yml|csv|html|htm)
                local fhash=$(_file_sha256 "$file")
                local content
                content=$(_cache_get "$fhash" 2>/dev/null) && {
                    local word_count=$(echo "$content" | wc -w | tr -d ' ')
                    echo -e "    ${GREEN}📄${NC} $basename ${DIM}($word_count words, cached)${NC}"
                    _scan_log "EXTRACT" "file=$basename, type=$ext, words=$word_count, cache=HIT"
                } || {
                    content=$(cat "$file")
                    _cache_set "$fhash" "$content"
                    local word_count=$(echo "$content" | wc -w | tr -d ' ')
                    echo -e "    ${GREEN}📄${NC} $basename ${DIM}($word_count words)${NC}"
                    _scan_log "EXTRACT" "file=$basename, type=$ext, words=$word_count, cache=MISS"
                }
                all_text+="
--- FILE: $basename ---
$content
"
                file_count=$((file_count + 1))
                ;;
            pdf)
                local fhash=$(_file_sha256 "$file")
                local content
                content=$(_cache_get "$fhash" 2>/dev/null) && {
                    local word_count=$(echo "$content" | wc -w | tr -d ' ')
                    echo -e "    ${GREEN}📄${NC} $basename ${DIM}($word_count words, PDF cached)${NC}"
                    _scan_log "EXTRACT" "file=$basename, type=pdf, words=$word_count, cache=HIT"
                } || {
                    content=""
                    local extractor="none"
                    if command -v pdftotext &>/dev/null; then
                        content=$(pdftotext "$file" - 2>/dev/null)
                        extractor="pdftotext"
                    elif command -v python3 &>/dev/null; then
                        content=$(python3 -c "
import subprocess, sys
filepath = sys.argv[1]
try:
    import PyPDF2
    reader = PyPDF2.PdfReader(filepath)
    for page in reader.pages:
        print(page.extract_text() or '')
except ImportError:
    try:
        result = subprocess.run(['textutil', '-convert', 'txt', '-stdout', filepath], 
