def find_scoutica_json(text):
    # 1. Look for markdown fences first
    fence_matches = re.findall(r'```(?:json)?\s*(\{[\s\S]*?\})\s*```', text)
    for fm in fence_matches:
        try:
            d = json.loads(fm)
            if 'profile' in d or 'rules' in d: return d
        except: pass
        
    # 2. Bracket counting from the end (to skip early stderr logs / crash traces)
    start_indices = [i for i, c in enumerate(text) if c == '{']
    start_indices.reverse()
    
    for start in start_indices:
        stack = 0
        for i in range(start, len(text)):
            if text[i] == '{':
                stack += 1
            elif text[i] == '}':
                stack -= 1
                if stack == 0:
                    try:
                        parsed = json.loads(text[start:i+1])
                        if isinstance(parsed, dict) and ('profile' in parsed or 'rules' in parsed or 'evidence' in parsed):
