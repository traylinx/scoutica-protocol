# ─── REPLY Command ───────────────────────────────────────────────────────────

cmd_reply() {
    local message_id=""
    local action=""  # accept, reject, withdraw
    local reply_message=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --accept)   action="accept"; shift ;;
            --reject)   action="reject"; shift ;;
            --withdraw) action="withdraw"; shift ;;
            --message)  reply_message="$2"; shift 2 ;;
            *)          message_id="$1"; shift ;;
        esac
    done
    
    if [ -z "$message_id" ]; then
        error "No message ID specified."
        echo -e "  ${DIM}Usage: scoutica reply <message_id> --accept${NC}"
        echo -e "  ${DIM}       scoutica reply <message_id> --reject${NC}"
        exit 1
    fi
    
    if [ -z "$action" ]; then
        error "No action specified. Use --accept, --reject, or --withdraw"
        exit 1
    fi
    
    header "Send Reply"
    
    python3 - "$message_id" "$action" "$reply_message" <<'REPLY_SCRIPT'
import json, sys, os, hashlib
from datetime import datetime, timezone

message_id = sys.argv[1]
action = sys.argv[2]
reply_message = sys.argv[3] if len(sys.argv) > 3 else ""

now = datetime.now(timezone.utc)

# Find original message in inbox
inbox_dir = os.path.expanduser("~/.scoutica/inbox")
original = None
original_file = None

if os.path.exists(inbox_dir):
    for root, dirs, files in os.walk(inbox_dir):
        for fname in files:
            if fname.endswith('.json'):
                filepath = os.path.join(root, fname)
                try:
                    with open(filepath) as f:
                        msg = json.load(f)
                    if msg.get("message_id") == message_id:
                        original = msg
                        original_file = filepath
                        break
                except Exception:
                    pass
        if original:
            break

if not original:
    print(f"  ❌ Message not found: {message_id}")
    print(f"     Check your inbox with: scoutica inbox")
    sys.exit(1)

# Map action to response type
type_map = {
    "accept": "response.accept",
    "reject": "response.reject",
    "withdraw": "response.withdraw",
}
response_type = type_map.get(action, f"response.{action}")

# Generate reply message ID
reply_hash = hashlib.sha256(f"{message_id}:{action}:{now.isoformat()}".encode()).hexdigest()[:8]
reply_id = f"msg_{reply_hash}"

# Build response payload
payload = {}
if action == "reject":
    payload["reasons"] = [reply_message] if reply_message else ["auto_rejected_by_rules"]
    payload["auto_rejected"] = not bool(reply_message)
elif action == "accept":
    if reply_message:
        payload["message"] = reply_message
elif action == "withdraw":
    if reply_message:
        payload["reason"] = reply_message

# Build response envelope
response = {
    "message_id": reply_id,
    "type": response_type,
    "sender": original.get("sender", {}),  # Will be overridden by actual sender
    "recipient": original.get("sender", {}).get("card_url", ""),
    "conversation_id": original.get("conversation_id", ""),
    "in_reply_to": message_id,
    "timestamp": now.strftime("%Y-%m-%dT%H:%M:%SZ"),
    "ttl_hours": 168,
    "transport_used": "git",
    "payload": payload,
}

# Save to outbox
outbox_dir = os.path.expanduser("~/.scoutica/outbox")
os.makedirs(outbox_dir, exist_ok=True)
reply_file = os.path.join(outbox_dir, f"{reply_id}.json")
with open(reply_file, "w") as f:
    json.dump(response, f, indent=2, ensure_ascii=False)
    f.write("\n")

# Prepare for delivery
pending_dir = os.path.expanduser("~/.scoutica/pending_delivery")
sender_url = original.get("sender", {}).get("card_url", "unknown")
sender_hash = hashlib.sha256(sender_url.encode()).hexdigest()[:12]
delivery_dir = os.path.join(pending_dir, sender_hash)
os.makedirs(delivery_dir, exist_ok=True)
delivery_file = os.path.join(delivery_dir, f"{reply_id}.json")
with open(delivery_file, "w") as f:
    json.dump(response, f, indent=2, ensure_ascii=False)
    f.write("\n")

# Log
log_dir = os.path.expanduser("~/.scoutica/privacy")
os.makedirs(log_dir, exist_ok=True)
log_entry = {
    "event": "reply_sent",
    "message_id": reply_id,
    "in_reply_to": message_id,
    "type": response_type,
    "recipient": sender_url,
    "timestamp": now.strftime("%Y-%m-%dT%H:%M:%SZ"),
    "transport": "git",
}
log_file = os.path.join(log_dir, "access_log.jsonl")
with open(log_file, "a") as f:
    f.write(json.dumps(log_entry) + "\n")

# Move original to processed
processed_dir = os.path.expanduser("~/.scoutica/inbox/processed")
os.makedirs(processed_dir, exist_ok=True)
processed_file = os.path.join(processed_dir, os.path.basename(original_file))
os.rename(original_file, processed_file)

icons = {"accept": "✅", "reject": "❌", "withdraw": "🚪"}
icon = icons.get(action, "📩")

print(f"  {icon} Reply sent: {reply_id}")
print(f"     Action: {action}")
print(f"     In reply to: {message_id}")
print(f"     To: {sender_url}")
print(f"     Conversation: {original.get('conversation_id', '')}")
print()
print(f"  📬 Pending delivery at: {delivery_file}")
print(f"  📋 Original moved to: {processed_file}")
REPLY_SCRIPT
    
    echo ""
}

# ─── IDENTITY Command (Nostr Keypair) ────────────────────────────────────────

cmd_identity() {
