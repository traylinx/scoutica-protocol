                cat "$SCOUTICA_HOME/GENERATE_MY_CARD.md"
            fi
        fi
    else
        error "GENERATE_MY_CARD.md not found. Re-run the installer."
    fi
}

# ─── VALIDATE Command ────────────────────────────────────────────────────────

cmd_validate() {
    local card_dir="${1:-.}"
    
    header "Validate Skill Card"
    
    # Pre-check: are there any card files here?
    if [ ! -f "$card_dir/profile.json" ] && [ ! -f "$card_dir/SKILL.md" ]; then
        error "No Skill Card found in $card_dir"
        echo ""
        echo -e "  ${BOLD}Create your card first:${NC}"
        echo -e "  ${CYAN}scoutica scan <docs-folder>${NC}   Auto-generate from your CV (easiest)"
        echo -e "  ${CYAN}scoutica init${NC}                  Interactive wizard"
        echo ""
        exit 1
    fi
    
    # Check if Python is available
    local python_cmd=""
    if command -v python3 &>/dev/null; then
        python_cmd="python3"
    elif command -v python &>/dev/null; then
        python_cmd="python"
    else
        error "Python is required for schema validation"
        echo -e "  ${DIM}Install Python 3 and run: pip install jsonschema pyyaml${NC}"
        exit 1
    fi
    
    # Check for validation script in multiple locations
    local validator=""
    local script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    
    if [ -f "$SCOUTICA_HOME/bin/validate_card.py" ]; then
        validator="$SCOUTICA_HOME/bin/validate_card.py"
    elif [ -f "$script_dir/validate_card.py" ]; then
        validator="$script_dir/validate_card.py"
    elif [ -f "$SCOUTICA_HOME/tools/validate_card.py" ]; then
        validator="$SCOUTICA_HOME/tools/validate_card.py"
    fi
    
    if [ -z "$validator" ]; then
        error "Validation script not found. Re-run the installer."
        exit 1
    fi
    
    # Check for dependencies
    if ! $python_cmd -c "import jsonschema, yaml" 2>/dev/null; then
        warn "Missing Python dependencies. Installing..."
        $python_cmd -m pip install jsonschema pyyaml --quiet 2>/dev/null || {
            error "Failed to install dependencies"
            echo -e "  ${DIM}Run manually: pip install jsonschema pyyaml${NC}"
            exit 1
        }
    fi
    
    # Run validation
    $python_cmd "$validator" "$card_dir"
}

# ─── PUBLISH Command ─────────────────────────────────────────────────────────

cmd_publish() {
    local card_dir="${1:-.}"
    
    header "Publish to GitHub"
    
    # Check if git is available
    if ! command -v git &>/dev/null; then
        error "Git is not installed on your system."
        echo ""
        echo -e "  ${BOLD}To publish your Scoutica Protocol card, you need a free GitHub account.${NC}"
        echo -e "  1. Create an account: ${CYAN}https://github.com/signup${NC}"
        echo -e "  2. Install Git:        ${CYAN}https://git-scm.com/downloads${NC}"
        echo -e "  3. After installing, run ${CYAN}scoutica publish${NC} again."
        echo ""
        exit 1
    fi
    
    # Check if already a git repo
    if [ -d "$card_dir/.git" ]; then
        (
            cd "$card_dir"
            # Only stage known card files — never stage secrets or .env
            local card_files=(profile.json rules.yaml evidence.json SKILL.md scoutica.json)
            for cf in "${card_files[@]}"; do
                [ -f "$cf" ] && git add "$cf" 2>/dev/null
            done
            [ -d "rules" ] && git add rules/ 2>/dev/null
            
            # Preview changes to the user
            local changes
            changes=$(git status -s 2>/dev/null | grep -E 'profile\.json|rules\.yaml|evidence\.json|SKILL\.md|scoutica\.json|rules/') || true
            
            if [ -z "$changes" ]; then
                echo -e "  ${GREEN}✅${NC} Your Skill Card is already up to date!"
                local origin_url=$(git remote get-url origin 2>/dev/null || echo "")
                if [ -n "$origin_url" ]; then
                    local clean_url=$(echo "$origin_url" | sed 's/\.git$//')
                    echo -e "  ${DIM}Live at:${NC} $clean_url"
                fi
                return 0
            fi
            
            echo -e "  ${BOLD}The following changes will be published:${NC}"
            echo "$changes" | while read -r line; do
                echo -e "    ${CYAN}$line${NC}"
            done
            echo ""
            
            local msg="Update Scoutica Protocol Skill Card — $(date +%Y-%m-%d)"
            git commit -m "$msg" >/dev/null 2>&1
            
            # Try to push
            if git remote -v | grep -q "origin"; then
                echo -e "  ${DIM}Pushing to GitHub...${NC}"
                if git push origin "$(git branch --show-current)" >/dev/null 2>&1; then
                    echo -e "  ${GREEN}✅ Successfully published to GitHub!${NC}"
                    echo ""
                    
                    # Extract URL for the user
                    local origin_url=$(git remote get-url origin)
                    local clean_url=$(echo "$origin_url" | sed 's/\.git$//')
                    
                    echo -e "  ${BOLD}View on GitHub:${NC}"
                    echo -e "  $clean_url"
                    echo ""
                    echo -e "  ${BOLD}Test your live card:${NC}"
                    echo -e "  ${CYAN}scoutica resolve $clean_url${NC}"
                else
                    error "Push failed. Check your remote configuration or permissions."
                fi
            else
                warn "No remote 'origin' configured."
                echo -e "  ${DIM}Run: git remote add origin https://github.com/YOU/YOUR-CARD.git${NC}"
            fi
        )
    else
        echo -e "  ${BOLD}No git repo found. Let's set one up.${NC}"
        echo ""
        local repo_name=$(ask "GitHub repo name" "my-scoutica-card")
        local gh_user=$(ask "GitHub username")
        echo ""
        
        (
            cd "$card_dir"
            git init >/dev/null 2>&1
            # Only stage known card files
            local card_files=(profile.json rules.yaml evidence.json SKILL.md scoutica.json)
            for cf in "${card_files[@]}"; do
                [ -f "$cf" ] && git add "$cf" 2>/dev/null
            done
            [ -d "rules" ] && git add rules/ 2>/dev/null
            
            # Preview changes to the user
            local changes
            changes=$(git status -s 2>/dev/null | grep -E 'profile\.json|rules\.yaml|evidence\.json|SKILL\.md|scoutica\.json|rules/') || true
            echo -e "  ${BOLD}The following files are ready to publish:${NC}"
            echo "$changes" | while read -r line; do
                echo -e "    ${CYAN}$line${NC}"
            done
            
            git commit -m "Initial Scoutica Protocol Skill Card" >/dev/null 2>&1
            git branch -M main >/dev/null 2>&1
            git remote add origin "https://github.com/$gh_user/$repo_name.git" 2>/dev/null || true
            
            echo ""
            echo -e "  ${BOLD}Next steps:${NC}"
            echo -e "  1. Create an empty repo on GitHub: ${CYAN}https://github.com/new${NC}"
            echo -e "     Name it exactly: ${BOLD}$repo_name${NC}"
            echo -e "  2. Push your card: ${CYAN}git push -u origin main${NC}"
            echo ""
            echo -e "  ${BOLD}Test your live card after pushing:${NC}"
            echo -e "  ${CYAN}scoutica resolve https://github.com/$gh_user/$repo_name${NC}"
        )
    fi
}

# ─── INFO Command ─────────────────────────────────────────────────────────────

cmd_info() {
    local card_dir="${1:-.}"
    
    header "Skill Card Summary"
    
    if [ ! -f "$card_dir/profile.json" ]; then
        error "No Skill Card found in $card_dir"
        echo ""
        echo -e "  ${BOLD}Create your card first:${NC}"
        echo -e "  ${CYAN}scoutica scan <docs-folder>${NC}   Auto-generate from your CV (easiest)"
        echo -e "  ${CYAN}scoutica init${NC}                  Interactive wizard"
        echo ""
        exit 1
    fi
    
    # Parse profile.json with basic tools
    local name=$(grep -o '"name": *"[^"]*"' "$card_dir/profile.json" | head -1 | sed 's/"name": *"\(.*\)"/\1/')
    local title=$(grep -o '"title": *"[^"]*"' "$card_dir/profile.json" | head -1 | sed 's/"title": *"\(.*\)"/\1/')
    local seniority=$(grep -o '"seniority": *"[^"]*"' "$card_dir/profile.json" | head -1 | sed 's/"seniority": *"\(.*\)"/\1/')
    local availability=$(grep -o '"availability": *"[^"]*"' "$card_dir/profile.json" | head -1 | sed 's/"availability": *"\(.*\)"/\1/')
    
    echo -e "  ${BOLD}$name${NC}"
    echo -e "  $title ${DIM}($seniority)${NC}"
    echo -e "  Availability: $availability"
    echo ""
    
    # Count skills
    local skill_count=$(grep -c '"[^"]*"' "$card_dir/profile.json" 2>/dev/null || echo "?")
    echo -e "  ${DIM}Profile:${NC} profile.json"
    
    # Check rules
    if [ -f "$card_dir/rules.yaml" ]; then
        local remote=$(grep "policy:" "$card_dir/rules.yaml" | head -1 | sed 's/.*: *"\?\([^"]*\)"\?/\1/')
        echo -e "  ${DIM}Remote:${NC} $remote"
    fi
    
    # Count evidence
    if [ -f "$card_dir/evidence.json" ]; then
        local ev_count=$(grep -c '"type":' "$card_dir/evidence.json" 2>/dev/null || echo "0")
        echo -e "  ${DIM}Evidence:${NC} $ev_count items"
    fi
    
    # Check rules dir
    if [ -d "$card_dir/rules" ]; then
        local rule_count=$(ls "$card_dir/rules/"*.md 2>/dev/null | wc -l | tr -d ' ')
        echo -e "  ${DIM}Rules:${NC} $rule_count rule files"
    fi
    
    echo ""
    echo -e "  ${BOLD}Next steps:${NC}"
    echo -e "  ${CYAN}scoutica validate $card_dir${NC}   Check for schema errors"
    echo -e "  ${CYAN}scoutica publish $card_dir${NC}    Push to GitHub"
    echo ""
}

# ─── DOCTOR Command ───────────────────────────────────────────────────────────

cmd_doctor() {
    header "Scoutica Doctor — System Check"
    echo ""
    local warnings=0
    local errors=0

    # 1. CLI installation
    local cli_path="$SCOUTICA_HOME/bin/scoutica"
    if [ -x "$cli_path" ]; then
        success "CLI installed at $cli_path"
    else
        error "CLI not fully executable at $cli_path"
        errors=$((errors+1))
    fi

    # 2. PATH check
    if command -v scoutica >/dev/null 2>&1; then
        success "scoutica found in PATH"
    else
        error "scoutica not found in PATH"
        errors=$((errors+1))
    fi

    # 3. Templates
    if [ -d "$SCOUTICA_HOME/templates/rules" ]; then
        local rule_count=$(ls "$SCOUTICA_HOME/templates/rules/"*.md 2>/dev/null | wc -l | tr -d ' ')
        success "Templates present ($rule_count rule files + card.gitignore)"
    else
        error "Templates directory missing"
        errors=$((errors+1))
    fi

    # 4. Schemas
    if [ -d "$SCOUTICA_HOME/schemas" ]; then
        local schema_count=$(ls "$SCOUTICA_HOME/schemas/"*.json 2>/dev/null | wc -l | tr -d ' ')
        success "Schemas present ($schema_count JSON schemas)"
    else
        error "Schemas directory missing"
        errors=$((errors+1))
    fi

    # 5. Python 3
    if command -v python3 >/dev/null 2>&1; then
        local py_ver=$(python3 --version 2>&1)
        success "$py_ver"
    else
        error "Python 3 not found (Required for JSON generation)"
        errors=$((errors+1))
    fi

    # 6. Git
    if command -v git >/dev/null 2>&1; then
        local git_ver=$(git --version | head -n1 2>&1)
        success "$git_ver"
    else
        error "Git not found (Required for publishing)"
        errors=$((errors+1))
    fi

    # 7. PDF Totext
    if command -v pdftotext >/dev/null 2>&1; then
        success "pdftotext found (for PDF extraction)"
    else
        echo -e "  ⚠️  pdftotext not found (optional — install poppler-utils for better PDF support)"
        warnings=$((warnings+1))
    fi

    echo ""
    echo -e "${BOLD}AI Providers (for scoutica scan):${NC}"
    local ai_found=0
    for cli in gemini claude codex vibe opencode ollama ail; do
        if command -v "$cli" >/dev/null 2>&1; then
            success "$cli (installed)"
            ai_found=$((ai_found+1))
        fi
    done
    # Check ail specially (network service fallback if CLI wrapper is missing)
    if ! command -v "ail" >/dev/null 2>&1 && curl -sf http://localhost:18080/health &>/dev/null 2>&1; then
        success "ail / switchAILocal (running)"
        ai_found=$((ai_found+1))
    fi
    
    if [ $ai_found -eq 0 ]; then
        echo -e "  ${YELLOW}⚠️  No AI CLI found.${NC}"
        echo -e "  ${DIM}Install one to use 'scoutica scan' for auto-generation:${NC}"
        echo -e "    ${CYAN}gemini${NC}  → ${DIM}npm install -g @google/gemini-cli${NC}"
        echo -e "    ${CYAN}claude${NC}  → ${DIM}npm install -g @anthropic-ai/claude-code${NC}"
        echo -e "    ${CYAN}ollama${NC}  → ${DIM}https://ollama.com (runs 100% offline)${NC}"
        echo -e "  ${DIM}Without an AI CLI, you can still use --clipboard mode.${NC}"
        warnings=$((warnings+1))
    else
        echo -e "  ${DIM}$ai_found AI provider(s) available for scanning.${NC}"
    fi

    echo ""
    echo -e "  ${DIM}Result: $warnings warnings, $errors errors.${NC}"
    if [ $errors -eq 0 ]; then
        success "Scoutica Protocol is ready!"
    else
        error "Please fix the errors above."
        exit 1
    fi
}

