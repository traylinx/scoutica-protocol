    case "$subcommand" in
        init)  cmd_identity_init "$@" ;;
        show)  cmd_identity_show "$@" ;;
        *)
            echo ""
            echo -e "${BOLD}scoutica identity${NC} — Cryptographic Identity Management"
            echo ""
            echo -e "  ${CYAN}identity init${NC}    Generate a Nostr keypair (secp256k1)"
            echo -e "  ${CYAN}identity show${NC}    Display your public key"
            echo ""
            ;;
    esac
}

cmd_identity_init() {
    header "Generate Nostr Identity"
    
    local identity_dir="$HOME/.scoutica/identity"
    
    if [ -f "$identity_dir/keypair.json" ]; then
        warn "Identity already exists at $identity_dir/keypair.json"
        if ! confirm "Overwrite existing identity?"; then
            echo -e "  ${DIM}Keeping existing identity.${NC}"
            return 0
        fi
    fi
    
    python3 - "$identity_dir" <<'IDENTITY_SCRIPT'
import json, sys, os, hashlib, secrets
from datetime import datetime, timezone

identity_dir = sys.argv[1]
os.makedirs(identity_dir, exist_ok=True)

# Generate a secp256k1-compatible private key
# (32 random bytes, hex-encoded)
private_key_bytes = secrets.token_bytes(32)
private_key_hex = private_key_bytes.hex()

# Derive public key (simplified — for full secp256k1, use a library)
# For now, generate a deterministic pubkey hash as placeholder
# In production, this would use actual secp256k1 point multiplication
pubkey_hash = hashlib.sha256(private_key_bytes).hexdigest()

# Create npub-style identifier (Bech32 encoding would be ideal, using hex for now)
npub_placeholder = f"npub1{pubkey_hash[:58]}"
nsec_placeholder = f"nsec1{private_key_hex[:58]}"

now = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

identity = {
    "created_at": now,
    "algorithm": "secp256k1",
