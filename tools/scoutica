    echo -e "  ${CYAN}GitHub:${NC}   https://github.com/traylinx/scoutica-protocol"
    echo -e "  ${CYAN}Guide:${NC}    ${SCOUTICA_HOME:-~/.scoutica}/GENERATE_MY_CARD.md"
    echo ""
}

