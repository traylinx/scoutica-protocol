    echo -e "  ${MAGENTA}━━━ 🛠️  Skills & Expertise ━━━${NC}"
    echo ""
    local domains=$(ask_list "Primary domains" "e.g. Backend Engineering, DevOps")
    local skills=$(ask_list "Key skills" "e.g. Python, Leadership, SQL")
    local tools=$(ask_list "Tools & platforms" "e.g. Docker, AWS, Figma")
    local certs=$(ask_list "Certifications" "optional, e.g. AWS SA, PMP")
    local specializations=$(ask_list "Specializations" "optional, e.g. Event-Driven Arch")
    
    echo ""
    
    # ── Section 3: Languages ──
    echo -e "  ${MAGENTA}━━━ 🌍 Languages ━━━${NC}"
    echo ""
    local languages_json="["
    local lang_first=true
    while true; do
        local lang=$(ask "Language" "")
        if [ -z "$lang" ]; then break; fi
        local level=$(ask_choice "Level for $lang" "native" "fluent" "professional" "basic")
        if ! $lang_first; then languages_json+=", "; fi
        languages_json+="{\"language\": \"$lang\", \"level\": \"$level\"}"
        lang_first=false
        if ! confirm "Add another language?"; then break; fi
    done
    languages_json+="]"
    
    echo ""
    
    # ── Section 4: Summary ──
    echo -e "  ${MAGENTA}━━━ 📝 Summary ━━━${NC}"
    echo ""
    local education=$(ask "Education" "")
    local summary=$(ask "Professional summary (2-3 sentences)" "")
    
    echo ""
    
    # ── Section 5: Rules of Engagement ──
    echo -e "  ${MAGENTA}━━━ 📋 Rules of Engagement ━━━${NC}"
    echo ""
    echo -e "  ${DIM}These rules tell AI agents what opportunities to accept or reject.${NC}"
    echo ""
    
    # Engagement types
    local engagement_types=""
    local eng_items=("permanent" "contract" "fractional" "advisory" "internship")
    echo -e "  ${BOLD}Which engagement types do you accept?${NC}"
    for etype in "${eng_items[@]}"; do
        if confirm "  Accept $etype?"; then
            if [ -n "$engagement_types" ]; then engagement_types+=","; fi
            engagement_types+="$etype"
        fi
    done
    
    echo ""
    
    # Compensation
    local comp_permanent="" comp_contract="" comp_advisory=""
    echo -e "  ${BOLD}Minimum compensation (EUR, or 'negotiable'):${NC}"
    if [[ "$engagement_types" == *"permanent"* ]]; then
        comp_permanent=$(ask "  Annual salary minimum" "negotiable")
    fi
    if [[ "$engagement_types" == *"contract"* ]]; then
        comp_contract=$(ask "  Daily rate minimum" "negotiable")
    fi
    if [[ "$engagement_types" == *"advisory"* ]]; then
        comp_advisory=$(ask "  Hourly rate minimum" "negotiable")
    fi
    
    echo ""
    
    # Remote policy
    local remote_policy=$(ask_choice "Remote policy" \
        "remote_only" "hybrid" "flexible" "on_site")
    
    local hybrid_locations=""
    if [ "$remote_policy" = "hybrid" ]; then
        hybrid_locations=$(ask_list "Hybrid locations" "e.g. Berlin, New York")
    fi
    
    echo ""
    
    # Filters
    local blocked=$(ask_list "Blocked industries" "optional, e.g. gambling, weapons")
    local preferred_stack=$(ask_list "Preferred tech/skill keywords" "for matching, e.g. Python, React")
    local stack_min=$(ask "Min keyword matches before soft-reject" "3")
    
    echo ""
    
    # ── Section 6: Evidence ──
    echo -e "  ${MAGENTA}━━━ 🔗 Public Evidence ━━━${NC}"
    echo ""
    echo -e "  ${DIM}Add links to public work that proves your skills.${NC}"
    echo ""
    
    local evidence_items="[]"
    local ev_entries=()
    while true; do
        if ! confirm "Add an evidence item?"; then break; fi
        
        local ev_type=$(ask_choice "Type" \
            "github_repo" "website" "portfolio" "certificate" "article" \
            "review" "case_study" "publication" "video" "other")
        local ev_title=$(ask "Title")
        local ev_url=$(ask "URL")
        local ev_desc=$(ask "What does this prove?")
        local ev_skills=$(ask_list "Skills demonstrated" "comma-separated")
        
        # Store as tab-delimited entry (safe — no JSON escaping needed here)
        ev_entries+=("${ev_type}	${ev_title}	${ev_url}	${ev_desc}	${ev_skills}")
        echo ""
    done
    
    echo ""
    
    # ── Generate Files ──
    header "Generating Your Skill Card"
    
    mkdir -p "$target_dir/rules"
    
    # ── Symlink protection ──
    for f in profile.json rules.yaml evidence.json SKILL.md; do
        if [ -L "$target_dir/$f" ]; then
            error "Refusing to overwrite symlink: $target_dir/$f"
            exit 1
        fi
    done
    
    # ── Generate all files safely via Python ──
    # Build evidence entries as newline-separated, tab-delimited lines
    local ev_lines=""
    for entry in "${ev_entries[@]}"; do
        ev_lines+="${entry}"$'\n'
    done
    
    python3 << 'GENERATE_SCRIPT' - \
        "$target_dir" \
        "$name" "$title" "$seniority" "$years" "$availability" \
        "$domains" "$skills" "$tools" "$certs" "$specializations" \
        "$languages_json" "$education" "$summary" \
        "$engagement_types" "$comp_permanent" "$comp_contract" "$comp_advisory" \
        "$remote_policy" "$hybrid_locations" \
        "$blocked" "$preferred_stack" "$stack_min" \
        "$ev_lines"
import json, sys, os, re

args = sys.argv[1:]
target_dir = args[0]
name, title, seniority, years_str, availability = args[1:6]
