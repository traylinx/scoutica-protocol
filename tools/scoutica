# ─── SCAN Command ─────────────────────────────────────────────────────────────

cmd_scan() {
    local source_dir=""
    local output_dir="."
    local provider=""
    
    # Parse flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --output|-o) output_dir="$2"; shift 2 ;;
            --with|-w) provider="$2"; shift 2 ;;
            --clipboard|-c) provider="clipboard"; shift ;;
            --help|-h) 
                echo -e "  ${BOLD}Usage:${NC} scoutica scan <docs-folder> [options]" >&2
                echo "" >&2
                echo -e "  ${DIM}Reads your documents and generates a Skill Card using a local AI CLI.${NC}" >&2
                echo -e "  ${DIM}Your data never leaves your machine.${NC}" >&2
                echo "" >&2
                echo -e "  ${BOLD}Options:${NC}" >&2
                echo -e "    --output, -o <dir>    Output directory for card files (default: .)" >&2
                echo -e "    --with, -w <cli>      AI CLI to use: gemini, claude, ollama (auto-detected)" >&2
                echo -e "    --clipboard, -c       Just copy the prompt to clipboard (no AI call)" >&2
                echo "" >&2
                echo -e "  ${BOLD}Supported AI CLIs (auto-detected):${NC}" >&2
                echo -e "    ${CYAN}gemini${NC}     Google Gemini CLI    ${DIM}(github.com/google-gemini/gemini-cli)${NC}" >&2
                echo -e "    ${CYAN}claude${NC}     Claude Code CLI      ${DIM}(github.com/anthropics/claude-code)${NC}" >&2
                echo -e "    ${CYAN}codex${NC}      OpenAI Codex CLI     ${DIM}(github.com/openai/codex)${NC}" >&2
                echo -e "    ${CYAN}vibe${NC}       Mistral Vibe CLI     ${DIM}(github.com/mistralai/mistral-vibe)${NC}" >&2
                echo -e "    ${CYAN}opencode${NC}   OpenCode CLI         ${DIM}(github.com/opencode-ai/opencode)${NC}" >&2
                echo -e "    ${CYAN}ollama${NC}     Ollama (local LLM)   ${DIM}(ollama.com)${NC}" >&2
                echo -e "    ${CYAN}ail${NC}        switchAILocal        ${DIM}(github.com/traylinx/switchAILocal)${NC}" >&2
                echo -e "    ${CYAN}openclaw${NC}   OpenClaw             ${DIM}(github.com/openclaw/openclaw)${NC}" >&2
                echo "" >&2
                echo -e "  ${BOLD}Examples:${NC}" >&2
                echo -e "    scoutica scan ~/CV/                      ${DIM}# auto-detect CLI${NC}" >&2
                echo -e "    scoutica scan ~/CV/ --with gemini         ${DIM}# use Gemini CLI${NC}" >&2
                echo -e "    scoutica scan ~/CV/ --with codex          ${DIM}# use OpenAI Codex${NC}" >&2
                echo -e "    scoutica scan ~/CV/ --with ail            ${DIM}# use switchAILocal${NC}" >&2
                echo -e "    scoutica scan ~/CV/ --clipboard           ${DIM}# copy prompt to clipboard${NC}" >&2
                return 0
                ;;
            *) 
                if [ -z "$source_dir" ]; then
                    source_dir="$1"
                fi
                shift
                ;;
        esac
    done
    
    if [ -z "$source_dir" ]; then
        error "Usage: scoutica scan <docs-folder> [--output <dir>] [--with <provider>]"
        echo "" >&2
        echo -e "  ${DIM}Example (current folder):${NC}  scoutica scan . --with default" >&2
        
        # Detect available providers for the error message
        local available=""
        for cli in gemini claude codex vibe opencode ollama ail; do
            if command -v "$cli" >/dev/null 2>&1; then
                available="$available $cli"
            fi
        done
        if ! command -v "ail" >/dev/null 2>&1 && curl -sf http://localhost:18080/health &>/dev/null 2>&1; then
            available="$available ail"
        fi
        
        if [ -n "$available" ]; then
            local first=$(echo $available | awk '{print $1}')
            echo -e "  ${DIM}Example (specific AI):${NC}     scoutica scan ~/CV/ --with $first" >&2
            echo "" >&2
            echo -e "  ${BOLD}Installed AI providers you can use:${NC}${CYAN}$available${NC}" >&2
        else
            echo -e "  ${DIM}Example (clipboard):${NC}       scoutica scan ~/CV/ --clipboard" >&2
            echo "" >&2
            echo -e "  ${YELLOW}⚠ No AI CLIs installed. Use --clipboard mode.${NC}" >&2
        fi
        echo "" >&2
        exit 1
    fi
    
    if [ ! -d "$source_dir" ]; then
        error "Directory not found: $source_dir"
        exit 1
    fi
    
    header "AI-Powered Card Generation"
    
    # ── Check for existing card files ──
    local existing_files=()
    for f in profile.json rules.yaml evidence.json SKILL.md; do
        [ -f "$output_dir/$f" ] && existing_files+=("$f")
    done
    
    if [ ${#existing_files[@]} -gt 0 ]; then
        warn "Existing card files found in $output_dir:"
        for f in "${existing_files[@]}"; do
            echo -e "    ${YELLOW}•${NC} $f" >&2
        done
        echo "" >&2
        
        # Auto-backup
        local backup_dir="$output_dir/.backup/$(date +%Y%m%d_%H%M%S)"
        mkdir -p "$backup_dir"
        for f in "${existing_files[@]}"; do
            cp "$output_dir/$f" "$backup_dir/$f"
        done
        [ -d "$output_dir/rules" ] && cp -r "$output_dir/rules" "$backup_dir/rules" 2>/dev/null
        
        success "Backed up existing files to .backup/"
        echo -e "  ${DIM}Scan will overwrite with AI-generated versions.${NC}" >&2
        echo "" >&2
    fi
    
    # ── Step 1: Read all documents ──
    echo -e "  ${BLUE}→${NC} Scanning ${BOLD}$source_dir${NC}..."
    echo ""
    
    local all_text=""
    local file_count=0
    
    for file in "$source_dir"/*; do
        [ -f "$file" ] || continue
        local basename=$(basename "$file")
        
        # Skip generated card files (in case source == output dir)
        case "$basename" in
            profile.json|rules.yaml|evidence.json|SKILL.md|scoutica_prompt.txt) continue ;;
        esac
        
        local ext="${basename##*.}"
        ext=$(echo "$ext" | tr '[:upper:]' '[:lower:]')
        
        case "$ext" in
            md|txt|json|yaml|yml|csv|html|htm)
                local content=$(cat "$file")
                local word_count=$(echo "$content" | wc -w | tr -d ' ')
                echo -e "    ${GREEN}📄${NC} $basename ${DIM}($word_count words)${NC}"
                all_text+="
--- FILE: $basename ---
$content
"
                file_count=$((file_count + 1))
                ;;
            pdf)
                local content=""
                if command -v pdftotext &>/dev/null; then
                    content=$(pdftotext "$file" - 2>/dev/null)
                elif command -v python3 &>/dev/null; then
                    content=$(python3 -c "
import subprocess, sys
filepath = sys.argv[1]
try:
    import PyPDF2
    reader = PyPDF2.PdfReader(filepath)
    for page in reader.pages:
        print(page.extract_text() or '')
except ImportError:
    try:
        result = subprocess.run(['textutil', '-convert', 'txt', '-stdout', filepath], 
                              capture_output=True, text=True)
        print(result.stdout)
    except: pass
" "$file" 2>/dev/null)
                elif command -v textutil &>/dev/null; then
                    content=$(textutil -convert txt -stdout "$file" 2>/dev/null)
                fi
                
                if [ -n "$content" ]; then
                    local word_count=$(echo "$content" | wc -w | tr -d ' ')
                    echo -e "    ${GREEN}📄${NC} $basename ${DIM}($word_count words, extracted from PDF)${NC}"
                    all_text+="
--- FILE: $basename ---
$content
"
                    file_count=$((file_count + 1))
                else
                    echo -e "    ${YELLOW}⚠️${NC}  $basename ${DIM}(could not extract text — install pdftotext or PyPDF2)${NC}"
                fi
                ;;
            docx)
                local content=""
                if command -v textutil &>/dev/null; then
                    content=$(textutil -convert txt -stdout "$file" 2>/dev/null)
                elif command -v python3 &>/dev/null; then
                    content=$(python3 -c "
import sys
try:
    import docx
    doc = docx.Document(sys.argv[1])
    for p in doc.paragraphs: print(p.text)
except: pass
" "$file" 2>/dev/null)
                fi
                
                if [ -n "$content" ]; then
                    local word_count=$(echo "$content" | wc -w | tr -d ' ')
                    echo -e "    ${GREEN}📄${NC} $basename ${DIM}($word_count words, extracted from DOCX)${NC}"
                    all_text+="
--- FILE: $basename ---
$content
"
                    file_count=$((file_count + 1))
                else
                    echo -e "    ${YELLOW}⚠️${NC}  $basename ${DIM}(could not extract — install python-docx)${NC}"
                fi
                ;;
            jpg|jpeg|png|gif|svg|ico|mp4|zip|tar|gz|py|css|js)
                # Skip binary/code files silently
                ;;
            *)
                echo -e "    ${DIM}⏭️  $basename (skipped — unsupported format)${NC}"
                ;;
        esac
    done
    
    echo ""
    
    if [ "$file_count" -eq 0 ]; then
        error "No readable documents found in $source_dir"
        echo -e "  ${DIM}Supported formats: .md .txt .pdf .docx .json .yaml .csv .html${NC}" >&2
        exit 1
    fi
    
    echo -e "  ${GREEN}✅${NC} Found ${BOLD}$file_count${NC} documents"
    echo ""
    
    # ── Step 2: Load system prompt ──
    local scan_prompt=""
    local script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    
    if [ -f "$SCOUTICA_HOME/bin/SCAN_PROMPT.md" ]; then
        scan_prompt=$(cat "$SCOUTICA_HOME/bin/SCAN_PROMPT.md")
    elif [ -f "$script_dir/SCAN_PROMPT.md" ]; then
        scan_prompt=$(cat "$script_dir/SCAN_PROMPT.md")
    else
        scan_prompt="You are a Scoutica Protocol card generator. Analyze the candidate's documents and return ONLY a single JSON object with keys: profile, rules, evidence, skill_md. Follow the Scoutica Protocol schema exactly. Never invent skills not in the documents. Use 'negotiable' for unknown compensation. Return raw JSON only — no markdown fences."
    fi
    
    # ── Step 3: Build the full prompt ──
    local full_prompt="$scan_prompt

## Candidate Documents

$all_text"
    
    # ── Step 4: Detect or use specified AI CLI ──
    if [ -z "$provider" ] || [ "$provider" = "default" ]; then
        # Auto-detect in priority order
        if command -v gemini &>/dev/null; then
            provider="gemini"
        elif command -v claude &>/dev/null; then
            provider="claude"
        elif command -v codex &>/dev/null; then
            provider="codex"
        elif command -v vibe &>/dev/null; then
            provider="vibe"
