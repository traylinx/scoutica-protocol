# Scoutica <Agent> Agent - Environment Configuration Template
# Copy this file to .env and fill in the actual values

# ============================================================================
# AGENT IDENTITY
# ============================================================================
AGENT_KEY=scoutica-<agent>-agent
AGENT_SECRET=<secret-from-traylinx-sentinel>
AGENT_PORT=<port>  # 8000 for orchestrator, 8010+ for others

# ============================================================================
# TRAYLINX INFRASTRUCTURE
# ============================================================================
SENTINEL_URL=http://traylinx-sentinel:8002
REGISTRY_URL=http://traylinx-registry:8000
ROUTER_URL=http://traylinx-router:8080
SUBSCRIPTION_SERVICE_URL=http://traylinx-subscription:8001

# ============================================================================
# DATABASE (PostgreSQL ONLY - NO REDIS!)
# ============================================================================
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/<agent>_agent_dev
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
ENVIRONMENT=development  # development, staging, production

# ============================================================================
# AGENT-SPECIFIC SETTINGS
# ============================================================================

# For LLM-using agents (Conversation, JD, Matching, Screening):
# TRAYLINX_LLM_URL=https://api.traylinx.com
# TRAYLINX_LLM_MODEL=gpt-4

# For Conversation Agent:
# WHATSAPP_API_URL=https://graph.facebook.com/v18.0
# WHATSAPP_PHONE_NUMBER_ID=<phone-number-id>
# WHATSAPP_ACCESS_TOKEN=<access-token>

# For Sourcing Agent:
# CORESIGNAL_API_KEY=<api-key>
# CORESIGNAL_API_URL=https://api.coresignal.com/v1
# META_ADS_ACCESS_TOKEN=<access-token>
# META_ADS_API_URL=https://graph.facebook.com/v18.0

# For Matching Agent:
# GENERATE_EXPLANATIONS=true
# TOP_N_FOR_EXPLANATION=10

# For Screening Agent:
# SCREENING_SCORE_THRESHOLD=0.7

# ============================================================================
# OPTIONAL SETTINGS
# ============================================================================
# HEARTBEAT_INTERVAL_SECONDS=30
# MAX_RETRIES=3
# RETRY_BASE_DELAY_SECONDS=2
# CIRCUIT_BREAKER_THRESHOLD=5
# CIRCUIT_BREAKER_TIMEOUT_SECONDS=30

