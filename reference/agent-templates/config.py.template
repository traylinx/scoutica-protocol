"""
Configuration module for Scoutica <Agent> Agent.
Loads settings from environment variables using Pydantic v2.
"""

from pydantic import Field
from pydantic_settings import BaseSettings, SettingsConfigDict
from typing import Optional


class Settings(BaseSettings):
    """Agent configuration loaded from environment variables."""
    
    # ========================================================================
    # AGENT IDENTITY
    # ========================================================================
    AGENT_KEY: str = Field(
        ..., 
        description="Unique agent identifier (e.g., 'scoutica-conversation-agent')"
    )
    AGENT_SECRET: str = Field(
        ..., 
        description="Agent authentication secret from Traylinx Sentinel"
    )
    AGENT_PORT: int = Field(
        default=8000, 
        description="Server port"
    )
    
    # ========================================================================
    # TRAYLINX INFRASTRUCTURE
    # ========================================================================
    SENTINEL_URL: str = Field(
        ..., 
        description="Traylinx Sentinel URL for authentication"
    )
    REGISTRY_URL: str = Field(
        ..., 
        description="Traylinx Registry URL for agent registration"
    )
    ROUTER_URL: str = Field(
        ..., 
        description="Traylinx Router URL for event publishing/routing"
    )
    SUBSCRIPTION_SERVICE_URL: str = Field(
        ..., 
        description="Traylinx Subscription Service URL for event subscriptions"
    )
    
    # ========================================================================
    # DATABASE (PostgreSQL ONLY - NO REDIS!)
    # ========================================================================
    DATABASE_URL: str = Field(
        ..., 
        description="PostgreSQL connection URL (asyncpg driver)"
    )
    DB_POOL_SIZE: int = Field(
        default=20, 
        description="Database connection pool size"
    )
    DB_MAX_OVERFLOW: int = Field(
        default=10, 
        description="Max connections beyond pool size"
    )
    
    # ========================================================================
    # LOGGING & MONITORING
    # ========================================================================
    LOG_LEVEL: str = Field(
        default="INFO", 
        description="Logging level: DEBUG, INFO, WARNING, ERROR"
    )
    ENVIRONMENT: str = Field(
        default="development", 
        description="Environment: development, staging, production"
    )
    
    # ========================================================================
    # AGENT-SPECIFIC SETTINGS (Customize per agent)
    # ========================================================================
    
    # Example for LLM-using agents:
    # TRAYLINX_LLM_URL: Optional[str] = Field(
    #     None, 
    #     description="Traylinx LLM API URL"
    # )
    # TRAYLINX_LLM_MODEL: str = Field(
    #     default="gpt-4", 
    #     description="LLM model to use"
    # )
    
    # Example for Conversation Agent:
    # WHATSAPP_API_URL: Optional[str] = Field(None, description="WhatsApp API URL")
    # WHATSAPP_PHONE_NUMBER_ID: Optional[str] = Field(None, description="WhatsApp Phone Number ID")
    # WHATSAPP_ACCESS_TOKEN: Optional[str] = Field(None, description="WhatsApp Access Token")
    
    # Example for Sourcing Agent:
    # CORESIGNAL_API_KEY: Optional[str] = Field(None, description="Coresignal API Key")
    # CORESIGNAL_API_URL: Optional[str] = Field(None, description="Coresignal API URL")
    # META_ADS_ACCESS_TOKEN: Optional[str] = Field(None, description="Meta Ads Access Token")
    
    # ========================================================================
    # PYDANTIC v2 CONFIGURATION
    # ========================================================================
    model_config = SettingsConfigDict(
        env_file=".env",
        env_file_encoding="utf-8",
        case_sensitive=True,
        extra="ignore"  # CRITICAL: Prevents errors from extra env vars
    )


# Singleton pattern for settings
_settings: Optional[Settings] = None


def get_settings() -> Settings:
    """
    Get application settings (singleton).
    
    Returns:
        Settings instance loaded from environment
    """
    global _settings
    if _settings is None:
        _settings = Settings()
    return _settings


# Convenience function for testing
def reset_settings() -> None:
    """Reset settings singleton (useful for testing)."""
    global _settings
    _settings = None

