{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://scoutica.com/schemas/evidence.schema.json",
  "title": "Scoutica Evidence Registry",
  "description": "Schema for a candidate's public evidence registry. Evidence items prove claims about skills and experience through verifiable public artifacts.",
  "type": "object",
  "required": ["schema_version", "items"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version of the Scoutica schema this evidence registry conforms to.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "items": {
      "type": "array",
      "description": "List of public evidence items.",
      "items": {
        "type": "object",
        "required": ["type", "title", "url", "description", "skills_demonstrated"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Category of evidence. Use standard types when possible.",
            "enum": [
              "github_repo",
              "website",
              "portfolio",
              "certificate",
              "article",
              "review",
              "reference",
              "photo",
              "video",
              "case_study",
              "publication",
              "other"
            ]
          },
          "title": {
            "type": "string",
            "description": "Name or title of the evidence item.",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "description": "Public URL to the evidence.",
            "format": "uri"
          },
          "description": {
            "type": "string",
            "description": "What this evidence proves about the candidate's capabilities.",
            "minLength": 1
          },
          "skills_demonstrated": {
            "type": "array",
            "description": "Skills that this evidence demonstrates.",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
